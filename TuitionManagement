function exportData() {
  const blob = new Blob([JSON.stringify(db, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'classbook_backup_'+todayStr()+'.json';
  a.click();
}

function importData(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const parsed = JSON.parse(ev.target.result);
      if (!parsed.students || !parsed.classes) throw new Error('Invalid file');
      if (confirm('This will replace all current data. Continue?')) {
        db = parsed;
        save();
        init();
        alert('Data imported successfully!');
      }
    } catch { alert('Invalid backup file.'); }
  };
  reader.readAsText(file);
}

function clearAllData() {
  if (confirm('Delete ALL data permanently? This cannot be undone!')) {
    if (confirm('Are you absolutely sure?')) {
      db = { classes: ['Class 6-A', 'Class 7-B', 'Class 8-C'], students: [], attendance: {} };
      save(); init();
    }
  }
}

// ─── AT A GLANCE ──────────────────────────────────────
function getWeekBounds(date) {
  const d = new Date(date);
  const day = d.getDay();
  const diffToMon = (day === 0) ? -6 : 1 - day;
  const mon = new Date(d); mon.setDate(d.getDate() + diffToMon);
  const sun = new Date(mon); sun.setDate(mon.getDate() + 6);
  return { mon, sun };
}

function dateStr(d) { return d.toISOString().slice(0,10); }

function fmt(d) {
  return d.toLocaleDateString('en-IN', { day:'numeric', month:'short' });
}

function getStudentStats(sid, dateList) {
  let p=0, a=0, l=0;
  dateList.forEach(ds => {
    const v = db.attendance[ds]?.[sid];
    if (v==='P') p++;
    else if (v==='A') a++;
    else if (v==='L') l++;
  });
  const total = p+a+l;
  const pct = total===0 ? null : Math.round((p/total)*100);
  return { p, a, l, total, pct };
}

function pctColor(pct) {
  if (pct === null) return '#9ca3af';
  if (pct >= 75) return '#10b981';
  if (pct >= 50) return '#f59e0b';
  return '#ef4444';
}

function pctBg(pct) {
  if (pct === null) return '#f3f4f6';
  if (pct >= 75) return '#d1fae5';
  if (pct >= 50) return '#fef3c7';
  return '#fee2e2';
}

function pctText(pct) {
  if (pct === null) return '—';
  return pct + '%';
}

// ── Calendar state ─────────────────────────────────────
let calViewYear, calViewMonth;
let calRangeStart = null; // 'YYYY-MM-DD'
let calRangeEnd   = null;
let calSelecting  = false; // true = waiting for end date
let customRangeStart = null;
let customRangeEnd   = null;

function initCalendar() {
  const today = new Date();
  calViewYear  = today.getFullYear();
  calViewMonth = today.getMonth();
  // Default to current week
  const { mon, sun } = getWeekBounds(today);
  calRangeStart    = dateStr(mon);
  calRangeEnd      = dateStr(sun);
  customRangeStart = calRangeStart;
  customRangeEnd   = calRangeEnd;
  renderMiniCal();
  updateRangeDisplay();
}

function calNav(dir) {
  calViewMonth += dir;
  if (calViewMonth > 11) { calViewMonth = 0;  calViewYear++; }
  if (calViewMonth < 0)  { calViewMonth = 11; calViewYear--; }
  renderMiniCal();
}

function renderMiniCal() {
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('calMonthLabel').textContent = `${MONTHS[calViewMonth]} ${calViewYear}`;

  const today = dateStr(new Date());
  const allAttDates = new Set(Object.keys(db.attendance));

  // First day of the month
  const firstDay = new Date(calViewYear, calViewMonth, 1);
  // Monday-based offset (0=Mon … 6=Sun)
  let startOffset = firstDay.getDay() - 1;
  if (startOffset < 0) startOffset = 6;

  const daysInMonth = new Date(calViewYear, calViewMonth+1, 0).getDate();
  // Days from previous month to fill
  const prevMonthDays = new Date(calViewYear, calViewMonth, 0).getDate();

  let cells = '';
  const totalCells = Math.ceil((startOffset + daysInMonth) / 7) * 7;

  for (let i = 0; i < totalCells; i++) {
    let day, ds, classes = 'mini-cal-day';

    if (i < startOffset) {
      // Previous month
      day = prevMonthDays - startOffset + i + 1;
      const prevM = calViewMonth === 0 ? 11 : calViewMonth - 1;
      const prevY = calViewMonth === 0 ? calViewYear - 1 : calViewYear;
      ds = `${prevY}-${String(prevM+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
      classes += ' other-month';
    } else if (i >= startOffset + daysInMonth) {
      // Next month
      day = i - startOffset - daysInMonth + 1;
      const nextM = calViewMonth === 11 ? 0 : calViewMonth + 1;
      const nextY = calViewMonth === 11 ? calViewYear + 1 : calViewYear;
      ds = `${nextY}-${String(nextM+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
      classes += ' other-month';
    } else {
      day = i - startOffset + 1;
      ds = `${calViewYear}-${String(calViewMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    }

    if (ds === today) classes += ' today';
    if (allAttDates.has(ds) && !classes.includes('other-month')) classes += ' has-data';

    // Range highlight
    if (calRangeStart && calRangeEnd) {
      const lo = calRangeStart < calRangeEnd ? calRangeStart : calRangeEnd;
      const hi = calRangeStart < calRangeEnd ? calRangeEnd   : calRangeStart;
      if (ds === lo && ds === hi) classes += ' range-start range-end';
      else if (ds === lo)         classes += ' range-start';
      else if (ds === hi)         classes += ' range-end';
      else if (ds > lo && ds < hi) classes += ' in-range';
    } else if (calRangeStart && ds === calRangeStart) {
      classes += ' range-start range-end';
    }

    cells += `<div class="${classes}" data-ds="${ds}" onclick="calDayClick('${ds}')">${day}</div>`;
  }

  document.getElementById('miniCalGrid').innerHTML = cells;
}

function calDayClick(ds) {
  // Activate custom preset
  document.querySelectorAll('.range-preset').forEach(b => b.classList.toggle('active', b.dataset.range === 'custom'));

  if (!calSelecting || !calRangeStart) {
    // Start selection
    calRangeStart = ds;
    calRangeEnd   = null;
    calSelecting  = true;
  } else {
    // End selection
    calRangeEnd  = ds;
    calSelecting = false;
    // Normalise order
    if (calRangeStart > calRangeEnd) {
      [calRangeStart, calRangeEnd] = [calRangeEnd, calRangeStart];
    }
    customRangeStart = calRangeStart;
    customRangeEnd   = calRangeEnd;
  }
  renderMiniCal();
  updateRangeDisplay();
}

function updateRangeDisplay() {
  const el = document.getElementById('rangeSummaryText');
  if (!calRangeStart) { el.textContent = 'Tap a start date'; return; }
  if (!calRangeEnd || calSelecting) {
    // Count days
    const start = new Date(calRangeStart+'T00:00:00');
    el.innerHTML = `<span style="color:var(--accent)">From:</span> ${fmt(start)} — tap an end date`;
    return;
  }
  const start = new Date(calRangeStart+'T00:00:00');
  const end   = new Date(calRangeEnd+'T00:00:00');
  const days  = Math.round((end-start)/(1000*60*60*24))+1;
  // Count dates with attendance data in range
  const attInRange = Object.keys(db.attendance).filter(d => d >= calRangeStart && d <= calRangeEnd).length;
  el.innerHTML = `<span style="color:var(--accent)">${fmt(start)}</span> → <span style="color:var(--accent)">${fmt(end)}</span> &nbsp;·&nbsp; ${days} day${days>1?'s':''} &nbsp;·&nbsp; ${attInRange} session${attInRange!==1?'s':''}`;
}

function applyPreset(range) {
  const today = new Date();
  calSelecting = false;
  document.querySelectorAll('.range-preset').forEach(b => b.classList.toggle('active', b.dataset.range === range));

  if (range === 'thisweek') {
    const { mon, sun } = getWeekBounds(today);
    calRangeStart = dateStr(mon); calRangeEnd = dateStr(sun);
    calViewYear = mon.getFullYear(); calViewMonth = mon.getMonth();
  } else if (range === 'lastweek') {
    const lw = new Date(today); lw.setDate(today.getDate()-7);
    const { mon, sun } = getWeekBounds(lw);
    calRangeStart = dateStr(mon); calRangeEnd = dateStr(sun);
    calViewYear = mon.getFullYear(); calViewMonth = mon.getMonth();
  } else if (range === 'thismonth') {
    const mFirst = new Date(today.getFullYear(), today.getMonth(), 1);
    const mLast  = new Date(today.getFullYear(), today.getMonth()+1, 0);
    calRangeStart = dateStr(mFirst); calRangeEnd = dateStr(mLast);
    calViewYear = today.getFullYear(); calViewMonth = today.getMonth();
  } else if (range === 'lastmonth') {
    const lmFirst = new Date(today.getFullYear(), today.getMonth()-1, 1);
    const lmLast  = new Date(today.getFullYear(), today.getMonth(), 0);
    calRangeStart = dateStr(lmFirst); calRangeEnd = dateStr(lmLast);
    calViewYear = lmFirst.getFullYear(); calViewMonth = lmFirst.getMonth();
  } else if (range === 'last7') {
    const ago = new Date(today); ago.setDate(today.getDate()-6);
    calRangeStart = dateStr(ago); calRangeEnd = dateStr(today);
    calViewYear = today.getFullYear(); calViewMonth = today.getMonth();
  } else if (range === 'last30') {
    const ago = new Date(today); ago.setDate(today.getDate()-29);
    calRangeStart = dateStr(ago); calRangeEnd = dateStr(today);
    calViewYear = today.getFullYear(); calViewMonth = today.getMonth();
  } else if (range === 'custom') {
    // restore last custom selection
    calRangeStart = customRangeStart;
    calRangeEnd   = customRangeEnd;
  }
  renderMiniCal();
  updateRangeDisplay();
}

// Wire up preset buttons (called once in init)
function initRangePresets() {
  document.querySelectorAll('.range-preset').forEach(btn => {
    btn.addEventListener('click', () => applyPreset(btn.dataset.range));
  });
}

function applyRange() {
  if (!calRangeStart || !calRangeEnd) {
    alert('Please select a start and end date first.');
    return;
  }
  renderGlance();
}

// ─── STUDENT NAME PICKER ──────────────────────────────
let selectedStudentIds = new Set(); // empty = show prompt
let pickerApplied = false;          // true once user hits "Show Selected"

function renderPicker() {
  const q = (document.getElementById('pickerSearch')?.value || '').toLowerCase();
  const clsFilter = document.getElementById('glanceClassFilter').value;

  let list = [...db.students];
  if (clsFilter) list = list.filter(s => s.cls === clsFilter);
  list.sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    return (parseInt(a.roll)||999) - (parseInt(b.roll)||999);
  });
  if (q) list = list.filter(s =>
    s.name.toLowerCase().includes(q) ||
    (s.roll||'').toLowerCase().includes(q) ||
    (s.cls||'').toLowerCase().includes(q)
  );

  const el = document.getElementById('pickerList');
  if (!list.length) {
    el.innerHTML = `<div style="font-size:0.82rem;color:var(--muted);text-align:center;padding:10px;">No students found.</div>`;
    updatePickerCount();
    return;
  }

  el.innerHTML = list.map(s => {
    const checked = selectedStudentIds.has(s.id);
    return `
    <label style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:10px;cursor:pointer;
      background:${checked ? '#ede9fe' : 'var(--bg)'};border:1.5px solid ${checked ? 'var(--accent)' : 'transparent'};
      transition:all 0.12s;" onclick="togglePickStudent('${s.id}')">
      <div style="width:20px;height:20px;border-radius:5px;border:2px solid ${checked ? 'var(--accent)' : '#d1d5db'};
        background:${checked ? 'var(--accent)' : 'white'};display:flex;align-items:center;justify-content:center;
        flex-shrink:0;transition:all 0.12s;">
        ${checked ? '<span style="color:white;font-size:0.75rem;font-weight:900;">✓</span>' : ''}
      </div>
      <div class="avatar" style="background:${getColor(s.name)};width:30px;height:30px;font-size:0.72rem;flex-shrink:0;">${initials(s.name)}</div>
      <div style="flex:1;min-width:0;">
        <div style="font-weight:700;font-size:0.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${s.name}</div>
        <div style="font-size:0.68rem;color:var(--muted);">${s.cls}${s.roll ? ' • #'+s.roll : ''}</div>
      </div>
    </label>`;
  }).join('');

  updatePickerCount();
}

function togglePickStudent(id) {
  if (selectedStudentIds.has(id)) selectedStudentIds.delete(id);
  else selectedStudentIds.add(id);
  renderPicker();
}

function glanceSelectAll() {
  const clsFilter = document.getElementById('glanceClassFilter').value;
  let list = db.students;
  if (clsFilter) list = list.filter(s => s.cls === clsFilter);
  list.forEach(s => selectedStudentIds.add(s.id));
  renderPicker();
}

function glanceSelectNone() {
  selectedStudentIds.clear();
  renderPicker();
}

function updatePickerCount() {
  const el = document.getElementById('pickerCount');
  if (!el) return;
  const n = selectedStudentIds.size;
  el.textContent = n === 0 ? 'No students selected' : `${n} student${n > 1 ? 's' : ''} selected`;
  el.style.color = n === 0 ? '#ef4444' : 'var(--muted)';
}

function applyStudentPicker() {
  if (selectedStudentIds.size === 0) {
    alert('Please select at least one student.');
    return;
  }
  pickerApplied = true;
  renderGlance();
}

function renderGlance() {
  const clsFilter = document.getElementById('glanceClassFilter').value;
  const today = new Date();

  // Refresh picker list whenever glance re-renders (class filter may have changed)
  renderPicker();

  // Current week bounds (Mon–Sun)
  const { mon: wMon, sun: wSun } = getWeekBounds(today);

  // Current month bounds
  const mFirst = new Date(today.getFullYear(), today.getMonth(), 1);
  const mLast  = new Date(today.getFullYear(), today.getMonth()+1, 0);

  const allDates = Object.keys(db.attendance);
  const weekDates  = allDates.filter(ds => ds >= dateStr(wMon) && ds <= dateStr(wSun));
  const monthDates = allDates.filter(ds => ds >= dateStr(mFirst) && ds <= dateStr(mLast));

  // Custom range dates (from calendar)
  const rangeStart = calRangeStart || dateStr(wMon);
  const rangeEnd   = calRangeEnd   || dateStr(wSun);
  const rangeDates = allDates.filter(ds => ds >= rangeStart && ds <= rangeEnd);

  // All students for top-strip calculation (respect class filter only)
  let allStudents = [...db.students];
  if (clsFilter) allStudents = allStudents.filter(s => s.cls === clsFilter);
  allStudents.sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    return (parseInt(a.roll)||999) - (parseInt(b.roll)||999);
  });

  // Top strip always reflects all students in the class filter
  const instWeekP   = allStudents.reduce((s,st) => s + weekDates.filter(d => db.attendance[d]?.[st.id]==='P').length, 0);
  const instWeekT   = allStudents.reduce((s,st) => s + weekDates.filter(d => db.attendance[d]?.[st.id] !== undefined).length, 0);
  const instMonP    = allStudents.reduce((s,st) => s + monthDates.filter(d => db.attendance[d]?.[st.id]==='P').length, 0);
  const instMonT    = allStudents.reduce((s,st) => s + monthDates.filter(d => db.attendance[d]?.[st.id] !== undefined).length, 0);
  const instWeekPct = instWeekT===0 ? null : Math.round((instWeekP/instWeekT)*100);
  const instMonPct  = instMonT===0  ? null : Math.round((instMonP/instMonT)*100);

  document.getElementById('glanceTopStrip').innerHTML = `
    <div class="top-strip-card">
      <div class="top-strip-num" style="color:var(--accent)">${allStudents.length}</div>
      <div class="top-strip-label">Total Students</div>
    </div>
    <div class="top-strip-card">
      <div class="top-strip-num" style="color:${pctColor(instWeekPct)}">${pctText(instWeekPct)}</div>
      <div class="top-strip-label">This Week Avg</div>
    </div>
    <div class="top-strip-card">
      <div class="top-strip-num" style="color:${pctColor(instMonPct)}">${pctText(instMonPct)}</div>
      <div class="top-strip-label">This Month Avg</div>
    </div>
  `;

  // Range label
  const rStart = new Date(rangeStart+'T00:00:00');
  const rEnd   = new Date(rangeEnd+'T00:00:00');
  const rangeLabel = rangeStart === rangeEnd
    ? `Selected: ${fmt(rStart)}`
    : `Selected Range: ${fmt(rStart)} – ${fmt(rEnd)}`;
  document.getElementById('glanceWeekLabel').textContent = rangeLabel;

  // Cards: only show if picker has been applied with selections
  const listEl = document.getElementById('glanceList');

  if (!pickerApplied || selectedStudentIds.size === 0) {
    listEl.innerHTML = `
      <div style="text-align:center;padding:30px 20px;color:var(--muted);">
        <div style="font-size:2.5rem;margin-bottom:10px;">☝️</div>
        <div style="font-weight:700;font-size:0.95rem;color:var(--text);margin-bottom:6px;">No students selected yet</div>
        <div style="font-size:0.82rem;">Use the <b>Pick Students</b> panel above to choose one or more students,<br>then tap <b>Show Selected →</b> to view their attendance cards.</div>
      </div>`;
    return;
  }

  // Filter to selected students only
  const students = allStudents.filter(s => selectedStudentIds.has(s.id));
  if (!students.length) {
    listEl.innerHTML = `<div class="empty-state"><div class="empty-icon">🎒</div><p>None of the selected students were found.<br>Try a different class filter.</p></div>`;
    return;
  }

  const allDatesGlobal = Object.keys(db.attendance).sort();

  listEl.innerHTML = students.map(s => {
    const wk  = getStudentStats(s.id, weekDates);
    const mon = getStudentStats(s.id, monthDates);
    const rng = getStudentStats(s.id, rangeDates);
    const all = getStudentStats(s.id, allDatesGlobal);

    // Mini day-pip for current week
    const dayPips = Array.from({length:7},(_,i) => {
      const d = new Date(wMon); d.setDate(wMon.getDate()+i);
      const ds = dateStr(d);
      const v = db.attendance[ds]?.[s.id];
      const col = v==='P'?'#10b981':v==='A'?'#ef4444':v==='L'?'#f59e0b':'#e5e7eb';
      const lbl = ['Mo','Tu','We','Th','Fr','Sa','Su'][i];
      return `<span title="${lbl}" style="display:inline-flex;flex-direction:column;align-items:center;gap:2px;">
        <span style="font-size:0.55rem;color:var(--muted);font-weight:700;">${lbl}</span>
        <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${col};"></span>
      </span>`;
    }).join('');

    const panelHTML = (label, stat) => `
      <div class="glance-panel">
        <div class="glance-panel-label">${label}</div>
        <div class="glance-big" style="color:${pctColor(stat.pct)}">${stat.p}<span style="font-size:0.8rem;font-weight:600;color:var(--muted)">/${stat.total||'0'}</span></div>
        <div class="glance-sub">
          <span class="glance-dot" style="background:#10b981"></span>${stat.p}P
          <span class="glance-dot" style="background:#ef4444;margin-left:3px;"></span>${stat.a}A
          ${stat.l?`<span class="glance-dot" style="background:#f59e0b;margin-left:3px;"></span>${stat.l}L`:''}
        </div>
        <div class="glance-bar-wrap"><div class="glance-bar" style="width:${stat.pct||0}%;background:${pctColor(stat.pct)};"></div></div>
        <div style="font-size:0.68rem;font-weight:800;color:${pctColor(stat.pct)};margin-top:3px;">${pctText(stat.pct)}</div>
      </div>`;

    return `
    <div class="glance-card">
      <div class="glance-top">
        <div class="avatar" style="background:${getColor(s.name)};width:40px;height:40px;font-size:0.95rem;flex-shrink:0;">${initials(s.name)}</div>
        <div style="flex:1;min-width:0;">
          <div class="glance-name">${s.name}</div>
          <div class="glance-meta">${s.cls}${s.roll?' • #'+s.roll:''}</div>
          <div style="margin-top:6px;display:flex;gap:5px;">${dayPips}</div>
        </div>
        <div style="text-align:right;flex-shrink:0;">
          <div style="font-family:'Nunito',sans-serif;font-size:1.3rem;font-weight:900;color:${pctColor(all.pct)}">${pctText(all.pct)}</div>
          <div style="font-size:0.62rem;color:var(--muted);font-weight:700;">ALL TIME</div>
        </div>
      </div>
      <div class="glance-panels" style="grid-template-columns:repeat(4,1fr);">
        ${panelHTML('This Week', wk)}
        ${panelHTML('This Month', mon)}
        ${panelHTML('Selected', rng)}
        ${panelHTML('Cumulative', all)}
      </div>
    </div>`;
  }).join('');
}


// ─── MONTHLY REPORT ───────────────────────────────────
const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function initMonthly() {
  const now = new Date();
  const mSel = document.getElementById('monthlyMonth');
  const ySel = document.getElementById('monthlyYear');
  // Populate month
  if (!mSel.options.length) {
    MONTH_NAMES.forEach((m,i) => {
      const o = document.createElement('option');
      o.value = i; o.textContent = m;
      if (i === now.getMonth()) o.selected = true;
      mSel.appendChild(o);
    });
  }
  // Populate year (current ±2)
  if (!ySel.options.length) {
    for (let y = now.getFullYear()-2; y <= now.getFullYear()+1; y++) {
      const o = document.createElement('option');
      o.value = y; o.textContent = y;
      if (y === now.getFullYear()) o.selected = true;
      ySel.appendChild(o);
    }
  }
  populateClassSelect('monthlyClass','',true);
  renderMonthly();
}

function getMonthlyData() {
  const month = parseInt(document.getElementById('monthlyMonth').value);
  const year  = parseInt(document.getElementById('monthlyYear').value);
  const clsFilter = document.getElementById('monthlyClass').value;

  const daysInMonth = new Date(year, month+1, 0).getDate();
  // Collect all dates in that month that have attendance data
  const dateCols = [];
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    dateCols.push(ds);
  }

  let students = db.students;
  if (clsFilter) students = students.filter(s => s.cls === clsFilter);
  students = [...students].sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    return (parseInt(a.roll)||999) - (parseInt(b.roll)||999);
  });

  return { month, year, daysInMonth, dateCols, students };
}

function renderMonthly() {
  const { month, year, daysInMonth, dateCols, students } = getMonthlyData();

  // Figure out which dates actually have any attendance marked
  const activeDates = dateCols.filter(ds => {
    const rec = db.attendance[ds];
    return rec && Object.keys(rec).length > 0;
  });

  // Summary cards
  let totalDays = activeDates.length;
  let totalP=0, totalA=0, totalL=0;
  students.forEach(s => {
    activeDates.forEach(ds => {
      const v = db.attendance[ds]?.[s.id];
      if (v==='P') totalP++;
      else if (v==='A') totalA++;
      else if (v==='L') totalL++;
    });
  });

  document.getElementById('monthlySummary').innerHTML = `
    <div class="summary-card"><div class="summary-num" style="color:var(--accent)">${students.length}</div><div class="summary-label">Students</div></div>
    <div class="summary-card"><div class="summary-num" style="color:var(--accent)">${totalDays}</div><div class="summary-label">School Days</div></div>
    <div class="summary-card"><div class="summary-num" style="color:var(--green)">${totalP}</div><div class="summary-label">Total Present</div></div>
    <div class="summary-card"><div class="summary-num" style="color:var(--red)">${totalA}</div><div class="summary-label">Total Absent</div></div>
  `;

  if (!students.length) {
    document.getElementById('monthlyGrid').innerHTML = `<div class="empty-state" style="padding:30px;"><div class="empty-icon">🎒</div><p>No students in this class.</p></div>`;
    return;
  }

  const DAY_SHORT = ['Su','Mo','Tu','We','Th','Fr','Sa'];

  // Header row: name | d1 | d2 ... | P | A | L | %
  const headerDays = dateCols.map((ds, idx) => {
    const d = new Date(ds+'T00:00:00');
    const dayName = DAY_SHORT[d.getDay()];
    const isActive = activeDates.includes(ds);
    return `<th class="day-cell" style="${!isActive?'opacity:0.4;':''}" title="${ds}">${idx+1}<br><span style="font-size:0.6rem;font-weight:500">${dayName}</span></th>`;
  }).join('');

  const bodyRows = students.map(s => {
    let p=0, a=0, l=0;
    const dayCells = dateCols.map(ds => {
      const v = db.attendance[ds]?.[s.id];
      if (v==='P') { p++; return `<td class="day-cell"><span class="dc-p">P</span></td>`; }
      if (v==='A') { a++; return `<td class="day-cell"><span class="dc-a">A</span></td>`; }
      if (v==='L') { l++; return `<td class="day-cell"><span class="dc-l">L</span></td>`; }
      const isActive = activeDates.includes(ds);
      return `<td class="day-cell">${isActive ? '<span class="dc-h">—</span>' : ''}</td>`;
    }).join('');
    const total = p + a + l;
    const pct = total === 0 ? '—' : Math.round((p/total)*100)+'%';
    const pctNum = total === 0 ? 100 : Math.round((p/total)*100);
    const pctClr = pctNum>=75?'#065f46':pctNum>=50?'#92400e':'#991b1b';
    const pctBg  = pctNum>=75?'#d1fae5':pctNum>=50?'#fef3c7':'#fee2e2';
    return `<tr>
      <td class="name-col">${s.roll?'#'+s.roll+' ':''}${s.name}<br><span style="font-size:0.68rem;color:var(--muted);font-weight:400;">${s.cls}</span></td>
      ${dayCells}
      <td class="summary-col" style="color:var(--green)">${p}</td>
      <td class="summary-col" style="color:var(--red)">${a}</td>
      <td class="summary-col" style="color:var(--yellow)">${l}</td>
      <td class="summary-col"><span style="background:${pctBg};color:${pctClr};padding:2px 7px;border-radius:50px;font-size:0.75rem;">${pct}</span></td>
    </tr>`;
  }).join('');

  document.getElementById('monthlyGrid').innerHTML = `
    <table class="monthly-table">
      <thead>
        <tr>
          <th class="name-col">Student</th>
          ${headerDays}
          <th class="summary-col">✅P</th>
          <th class="summary-col">❌A</th>
          <th class="summary-col">⏰L</th>
          <th class="summary-col">%</th>
        </tr>
      </thead>
      <tbody>${bodyRows}</tbody>
    </table>
  `;
}

// ─── EXCEL EXPORT ─────────────────────────────────────
function exportMonthlyExcel() {
  if (typeof XLSX === 'undefined') {
    alert('Excel library not loaded. Please check your internet connection and try again.');
    return;
  }

  const { month, year, daysInMonth, dateCols, students } = getMonthlyData();
  const clsFilter = document.getElementById('monthlyClass').value;
  const monthLabel = MONTH_NAMES[month] + ' ' + year;
  const DAY_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  const activeDates = dateCols.filter(ds => {
    const rec = db.attendance[ds];
    return rec && Object.keys(rec).length > 0;
  });

  const wb = XLSX.utils.book_new();

  // ── Sheet 1: Day-wise Attendance ──────────────────────
  const sheetData = [];

  // Title row
  sheetData.push([`Monthly Attendance Report — ${monthLabel}${clsFilter?' — '+clsFilter:''}`]);
  sheetData.push([`Generated on: ${new Date().toLocaleDateString('en-IN', {day:'2-digit',month:'long',year:'numeric'})}`]);
  sheetData.push([]);

  // Header row
  const headerRow = ['Roll No.', 'Student Name', 'Class'];
  dateCols.forEach((ds, i) => {
    const d = new Date(ds+'T00:00:00');
    headerRow.push(`${i+1}\n${DAY_SHORT[d.getDay()]}`);
  });
  headerRow.push('Present', 'Absent', 'Late', 'Attendance %');
  sheetData.push(headerRow);

  // Data rows
  students.forEach(s => {
    let p=0, a=0, l=0;
    const row = [s.roll||'', s.name, s.cls];
    dateCols.forEach(ds => {
      const v = db.attendance[ds]?.[s.id];
      if (v==='P') { p++; row.push('P'); }
      else if (v==='A') { a++; row.push('A'); }
      else if (v==='L') { l++; row.push('L'); }
      else { row.push(activeDates.includes(ds)?'—':''); }
    });
    const total = p+a+l;
    row.push(p, a, l, total===0 ? 'N/A' : Math.round((p/total)*100)+'%');
    sheetData.push(row);
  });

  // Summary footer
  sheetData.push([]);
  sheetData.push(['SUMMARY']);
  sheetData.push(['Total Students', students.length]);
  sheetData.push(['School Days (recorded)', activeDates.length]);

  const ws1 = XLSX.utils.aoa_to_sheet(sheetData);

  // Column widths
  const cols = [{ wch: 8 }, { wch: 22 }, { wch: 14 }];
  for (let i = 0; i < daysInMonth; i++) cols.push({ wch: 5 });
  cols.push({ wch: 9 }, { wch: 7 }, { wch: 6 }, { wch: 14 });
  ws1['!cols'] = cols;

  // Merge title cell
  ws1['!merges'] = [
    { s: {r:0,c:0}, e: {r:0,c:3+daysInMonth} },
    { s: {r:1,c:0}, e: {r:1,c:3+daysInMonth} },
  ];

  XLSX.utils.book_append_sheet(wb, ws1, 'Day-wise Attendance');

  // ── Sheet 2: Summary Report ────────────────────────────
  const s2Data = [];
  s2Data.push([`Attendance Summary — ${monthLabel}${clsFilter?' — '+clsFilter:''}`]);
  s2Data.push([]);
  s2Data.push(['Roll No.', 'Student Name', 'Class', 'Days Present', 'Days Absent', 'Days Late', 'Total Days', 'Attendance %', 'Status']);

  students.forEach(s => {
    let p=0, a=0, l=0;
    activeDates.forEach(ds => {
      const v = db.attendance[ds]?.[s.id];
      if (v==='P') p++;
      else if (v==='A') a++;
      else if (v==='L') l++;
    });
    const total = p+a+l;
    const pct = total===0 ? 'N/A' : Math.round((p/total)*100)+'%';
    const pctNum = total===0 ? 100 : Math.round((p/total)*100);
    const status = pctNum>=75 ? 'Regular' : pctNum>=50 ? 'Irregular' : 'Critical';
    s2Data.push([s.roll||'', s.name, s.cls, p, a, l, total, pct, status]);
  });

  const ws2 = XLSX.utils.aoa_to_sheet(s2Data);
  ws2['!cols'] = [{ wch:8 },{ wch:22 },{ wch:14 },{ wch:13 },{ wch:12 },{ wch:10 },{ wch:11 },{ wch:14 },{ wch:10 }];
  ws2['!merges'] = [{ s:{r:0,c:0}, e:{r:0,c:8} }];
  XLSX.utils.book_append_sheet(wb, ws2, 'Summary');

  // ── Sheet 3: Per-class breakdown (if All Classes) ──────
  if (!clsFilter && db.classes.length > 1) {
    db.classes.forEach(cls => {
      const clsStudents = students.filter(s => s.cls === cls);
      if (!clsStudents.length) return;
      const csData = [];
      csData.push([`${cls} — ${monthLabel}`]);
      csData.push([]);
      csData.push(['Roll No.', 'Student Name', 'Present', 'Absent', 'Late', 'Total Days', '%']);
      clsStudents.forEach(s => {
        let p=0, a=0, l=0;
        activeDates.forEach(ds => {
          const v = db.attendance[ds]?.[s.id];
          if (v==='P') p++; else if (v==='A') a++; else if (v==='L') l++;
        });
        const total=p+a+l;
        csData.push([s.roll||'', s.name, p, a, l, total, total===0?'N/A':Math.round((p/total)*100)+'%']);
      });
      const wsC = XLSX.utils.aoa_to_sheet(csData);
      wsC['!cols'] = [{wch:8},{wch:22},{wch:9},{wch:8},{wch:8},{wch:11},{wch:9}];
      wsC['!merges'] = [{ s:{r:0,c:0}, e:{r:0,c:6} }];
      XLSX.utils.book_append_sheet(wb, wsC, cls.replace(/[\/\\*\[\]:?]/g,'').substring(0,31));
    });
  }

  const filename = `ClassBook_Attendance_${monthLabel.replace(' ','_')}${clsFilter?'_'+clsFilter.replace(/\s+/g,'_'):''}.xlsx`;
  XLSX.writeFile(wb, filename);
}


