    { list: overdue,    label: '⚠️ Overdue',  color: '#991b1b', urgency: 'overdue' },
    { list: dueSoon,    label: '🔔 Due Soon',  color: '#92400e', urgency: 'soon'    },
    { list: upToDate,   label: '📅 Upcoming',  color: '#3730a3', urgency: 'ok'      },
  ];
  sections.forEach(({ list, label, color, urgency }) => {
    if (!list.length) return;
    html += `<div style="font-size:0.74rem;font-weight:800;color:${color};text-transform:uppercase;letter-spacing:0.04em;margin:10px 0 8px;">${label} (${list.length})</div>`;
    html += list.map(x => makeFeesCard(x, urgency)).join('');
  });

  if (noJoinDate.length) {
    html += `<div style="font-size:0.74rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.04em;margin:10px 0 8px;">📋 No Joining Date (${noJoinDate.length})</div>`;
    html += noJoinDate.map(({ s }) => {
      const isSelected = feesSelectedIds.has(s.id);
      return `
      <div id="fees-card-${s.id}" style="background:#f9fafb;border:1.5px solid ${isSelected?'var(--accent)':'var(--border)'};
        border-radius:14px;padding:13px 14px;margin-bottom:8px;display:flex;align-items:center;gap:10px;">
        <div onclick="toggleFeesSelect('${s.id}')" style="width:22px;height:22px;border-radius:6px;flex-shrink:0;cursor:pointer;
          border:2px solid ${isSelected?'var(--accent)':'#d1d5db'};background:${isSelected?'var(--accent)':'white'};
          display:flex;align-items:center;justify-content:center;transition:all 0.12s;">
          ${isSelected?'<span style="color:white;font-size:0.75rem;font-weight:900;">✓</span>':''}
        </div>
        <div class="avatar" style="background:${getColor(s.name)};width:36px;height:36px;font-size:0.8rem;flex-shrink:0;">${initials(s.name)}</div>
        <div style="flex:1;"><div style="font-weight:700;font-size:0.88rem;">${s.name}</div>
        <div style="font-size:0.7rem;color:var(--muted);">${s.cls} • No joining date set</div></div>
        <button class="btn btn-ghost btn-sm" onclick="openEditStudent('${s.id}')">Edit</button>
      </div>`;
    }).join('');
  }

  if (!html) html = `<div class="empty-state"><div class="empty-icon">🎉</div><p>No students found. Add students with a joining date!</p></div>`;
  document.getElementById('feesDueLabel').textContent = '';
  document.getElementById('feesDueList').innerHTML = html;
}

// ── Fees: paid/unpaid toggle & payment date ───────────
let feesSelectedIds = new Set();

function toggleFeesPaid(sid) {
  if (!db.feesPaid)    db.feesPaid    = {};
  if (!db.feesPayDates) db.feesPayDates = {};
  if (db.feesPaid[sid]) {
    delete db.feesPaid[sid];
    delete db.feesPayDates[sid];
  } else {
    db.feesPaid[sid]    = true;
    db.feesPayDates[sid] = todayStr();   // default to today
  }
  save();
  renderFees();
}

function setFeesPayDate(sid, val) {
  if (!db.feesPayDates) db.feesPayDates = {};
  db.feesPayDates[sid] = val;
  save();
  // Just update the badge text without full re-render to avoid losing focus
  renderFees();
}

// ── Fees picker ───────────────────────────────────────
function toggleFeesSelect(sid) {
  if (feesSelectedIds.has(sid)) feesSelectedIds.delete(sid);
  else feesSelectedIds.add(sid);
  renderFees();
}

function feesPickAll() {
  const q = (document.getElementById('feesPickerSearch')?.value || '').toLowerCase();
  let list = [...db.students];
  if (q) list = list.filter(s =>
    s.name.toLowerCase().includes(q) || (s.roll||'').toLowerCase().includes(q) || (s.cls||'').toLowerCase().includes(q)
  );
  list.forEach(s => feesSelectedIds.add(s.id));
  renderFees();
}

function feesPickNone() {
  feesSelectedIds.clear();
  renderFees();
}

// ── Fees send queue ───────────────────────────────────
let feesQueue      = [];   // array of student objects with phones
let feesQueueIdx   = 0;    // current position in queue
let feesQueueSentFlag = false; // did user tap "Sent" for current item?

function feesStartQueue() {
  if (feesSelectedIds.size === 0) { alert('No students selected.'); return; }
  const selected = db.students.filter(s => feesSelectedIds.has(s.id));
  const withPhone = selected.filter(s => s.phone || s.phone2);
  if (!withPhone.length) {
    alert('None of the selected students have a contact number saved.\nPlease add phone numbers under the Students tab.');
    return;
  }
  const noPhone = selected.length - withPhone.length;
  const msg = `Ready to send fees reminders to ${withPhone.length} student${withPhone.length>1?'s':''}${noPhone?' ('+noPhone+' skipped — no number)':''}.`
    + `\n\nHow it works:\n• App opens WhatsApp for one student at a time\n• You send the message\n• Come back and tap "Sent — Next →"\n• Repeat until all done\n\nStart?`;
  if (!confirm(msg)) return;
  feesQueue    = withPhone;
  feesQueueIdx = 0;
  feesQueueSentFlag = false;
  feesQueueRender();
  openModal('feesQueueModal');
}


function feesQueueDidOpen() {
  // Called when user taps "Open WhatsApp" — unlock Next after a short delay
  // so they have time to actually switch to WhatsApp and send
  feesQueueSentFlag = true;

  const openBtn = document.getElementById('feesQueueOpenBtn');
  openBtn.textContent      = '📲 Opened — go send, then tap Next →';
  openBtn.style.background = '#059669';

  // Update instruction
  document.getElementById('feesQueueInstruction').innerHTML =
    `✅ WhatsApp opened! Send the message there, then come back and tap <b>Step 2 — Next →</b> below.`;

  // Unlock Next button after 1.5 s (gives time to switch apps)
  setTimeout(() => {
    const nextBtn = document.getElementById('feesQueueNextBtn');
    if (nextBtn) {
      nextBtn.disabled      = false;
      nextBtn.style.opacity = '1';
      nextBtn.textContent   = '✅ Step 2 — Sent? Next →';
    }
  }, 1500);
}

function feesQueueNext() {
  feesQueueIdx++;
  feesQueueSentFlag = false;
  feesQueueRender();
}

function feesQueueSkip() {
  feesQueueIdx++;
  feesQueueSentFlag = false;
  feesQueueRender();
}

function feesQueueCancel() {
  closeModal('feesQueueModal');
  feesQueue         = [];
  feesQueueIdx      = 0;
  feesQueueSentFlag = false;
}

function feesQueueFinish() {
  const total = feesQueue.length;

  document.getElementById('feesQueueBar').style.width    = '100%';
  document.getElementById('feesQueueStatus').textContent = '🎉 All done!';

  document.getElementById('feesQueueStepBox').style.display = 'none';

  document.getElementById('feesQueueCard').innerHTML = `
    <div style="text-align:center;padding:10px 0;">
      <div style="font-size:2.8rem;margin-bottom:8px;">🎉</div>
      <div style="font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:900;color:var(--green);">All reminders sent!</div>
      <div style="font-size:0.82rem;color:var(--muted);margin-top:6px;">
        You've gone through all ${total} selected student${total > 1 ? 's' : ''}.
      </div>
    </div>`;

  document.getElementById('feesQueueMsg').style.display   = 'none';
  document.getElementById('feesQueueWALink').style.display = 'none';
  document.getElementById('feesQueueHint').style.display  = 'none';
  document.getElementById('feesQueueNextBtn').style.display = 'none';

  // Replace Skip with Close
  const skipBtn = document.querySelector('#feesQueueModal .btn-ghost');
  if (skipBtn) {
    skipBtn.textContent = '✓ Close';
    skipBtn.onclick     = () => {
      closeModal('feesQueueModal');
      // Restore modal elements for next use
      document.getElementById('feesQueueStepBox').style.display  = '';
      document.getElementById('feesQueueMsg').style.display      = '';
      document.getElementById('feesQueueWALink').style.display   = '';
      document.getElementById('feesQueueHint').style.display     = '';
      document.getElementById('feesQueueNextBtn').style.display  = '';
      skipBtn.textContent = '⏭ Skip';
      skipBtn.onclick     = feesQueueSkip;
    };
  }
}

function feesSendToSelected() { feesStartQueue(); } // keep old name working



// ─── PROSPECTS ────────────────────────────────────────
let editingProspectId = null;

function savePromoMessage() {
  promoMsg = document.getElementById('promoMessageText').value.trim() || DEFAULT_PROMO_MSG;
  localStorage.setItem('eloquent_promo_msg', promoMsg);
  const btn = event.target;
  btn.textContent = '✅ Saved!';
  setTimeout(() => btn.textContent = '💾 Save Message', 1500);
}

function sendPromoToAll() {
  const filter = document.querySelector('#prospectStatusFilter .class-chip.active')?.dataset.status || '';
  let list = db.prospects || [];
  if (filter) list = list.filter(p => p.status === filter);
  if (!list.length) { alert('No prospects to message!'); return; }
  if (!confirm(`Send WhatsApp message to all ${list.length} visible prospects?`)) return;
  // Open each WhatsApp link with a small delay
  list.forEach((p, i) => {
    const phone = p.phone || p.phone2;
    if (!phone) return;
    const msg = promoMsg.replace(/{name}/g, p.name || 'there');
    setTimeout(() => window.open(buildWhatsAppLink(phone, msg), '_blank'), i * 800);
  });
}

function openAddProspect() {
  editingProspectId = null;
  document.getElementById('prospectModalTitle').textContent = 'Add Prospect';
  document.getElementById('deleteProspectBtn').style.display = 'none';
  ['pName','pPhone','pPhone2','pStudent','pClass','pNotes'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('pStatus').value = 'New';
  document.getElementById('pSource').value = '';
  document.getElementById('pDate').value = todayStr();
  openModal('prospectModal');
}

function openEditProspect(id) {
  const p = (db.prospects||[]).find(x => x.id === id);
  if (!p) return;
  editingProspectId = id;
  document.getElementById('prospectModalTitle').textContent = 'Edit Prospect';
  document.getElementById('deleteProspectBtn').style.display = '';
  document.getElementById('pName').value    = p.name    || '';
  document.getElementById('pPhone').value   = p.phone   || '';
  document.getElementById('pPhone2').value  = p.phone2  || '';
  document.getElementById('pStudent').value = p.student || '';
  document.getElementById('pClass').value   = p.cls     || '';
  document.getElementById('pNotes').value   = p.notes   || '';
  document.getElementById('pStatus').value  = p.status  || 'New';
  document.getElementById('pSource').value  = p.source  || '';
  document.getElementById('pDate').value    = p.date    || '';
  openModal('prospectModal');
}

function saveProspect() {
  const name  = document.getElementById('pName').value.trim();
  const phone = document.getElementById('pPhone').value.trim();
  if (!name) { alert('Name is required!'); return; }
  if (!db.prospects) db.prospects = [];
  const data = {
    name,
    phone,
    phone2:  document.getElementById('pPhone2').value.trim(),
    student: document.getElementById('pStudent').value.trim(),
    cls:     document.getElementById('pClass').value.trim(),
    notes:   document.getElementById('pNotes').value.trim(),
    status:  document.getElementById('pStatus').value,
    source:  document.getElementById('pSource').value,
    date:    document.getElementById('pDate').value,
  };
  if (editingProspectId) {
    const idx = db.prospects.findIndex(p => p.id === editingProspectId);
    db.prospects[idx] = { ...db.prospects[idx], ...data };
  } else {
    db.prospects.push({ id: uid(), ...data });
  }
  save();
  renderProspects();
  closeModal('prospectModal');
}

function deleteProspect() {
  if (!confirm('Delete this prospect?')) return;
  db.prospects = (db.prospects||[]).filter(p => p.id !== editingProspectId);
  save();
  renderProspects();
  closeModal('prospectModal');
}

function selectProspectFilter(el, status) {
  document.querySelectorAll('#prospectStatusFilter .class-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderProspects();
}

const STATUS_COLORS = {
  'New':           { bg:'#ede9fe', text:'#5b21b6' },
  'Contacted':     { bg:'#dbeafe', text:'#1e40af' },
  'Interested':    { bg:'#fef3c7', text:'#92400e' },
  'Converted':     { bg:'#d1fae5', text:'#065f46' },
  'Not Interested':{ bg:'#fee2e2', text:'#991b1b' },
};
const STATUS_ICONS = { 'New':'🆕','Contacted':'📞','Interested':'⭐','Converted':'✅','Not Interested':'❌' };

function renderProspects() {
  if (!db.prospects) db.prospects = [];
  const q = (document.getElementById('prospectSearch')?.value||'').toLowerCase();
  const filter = document.querySelector('#prospectStatusFilter .class-chip.active')?.dataset.status || '';

  // Reload saved promo message
  const pmEl = document.getElementById('promoMessageText');
  if (pmEl && !pmEl._edited) pmEl.value = promoMsg;

  let list = [...db.prospects];
  if (q) list = list.filter(p => p.name.toLowerCase().includes(q) || (p.phone||'').includes(q) || (p.student||'').toLowerCase().includes(q));
  if (filter) list = list.filter(p => p.status === filter);
  list.sort((a,b) => (b.date||'').localeCompare(a.date||''));

  const el = document.getElementById('prospectList');
  if (!list.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">🌱</div><p>No prospects found.<br>Tap <b>Add Prospect</b> to start building your pipeline!</p></div>`;
    return;
  }

  el.innerHTML = list.map(p => {
    const sc = STATUS_COLORS[p.status] || STATUS_COLORS['New'];
    const si = STATUS_ICONS[p.status] || '🆕';
    const phone = p.phone || p.phone2 || '';
    const msg = promoMsg.replace(/{name}/g, p.name || 'there');
    const waLink = phone ? buildWhatsAppLink(phone, msg) : '';
    return `
    <div class="card" style="padding:14px;margin-bottom:10px;" onclick="openEditProspect('${p.id}')">
      <div style="display:flex;align-items:flex-start;gap:12px;">
        <div class="avatar" style="background:${getColor(p.name)};width:42px;height:42px;font-size:0.95rem;flex-shrink:0;">${initials(p.name)}</div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <div style="font-weight:800;font-size:0.95rem;font-family:'Nunito',sans-serif;">${p.name}</div>
            <span style="background:${sc.bg};color:${sc.text};padding:2px 9px;border-radius:50px;font-size:0.68rem;font-weight:800;">${si} ${p.status}</span>
          </div>
          ${p.student ? `<div style="font-size:0.75rem;color:var(--muted);margin-top:2px;">👦 ${p.student}${p.cls?' — '+p.cls:''}</div>` : ''}
          <div style="font-size:0.75rem;color:var(--muted);margin-top:2px;">
            ${phone ? `📞 ${phone}` : ''}
            ${p.source ? ` • ${p.source}` : ''}
            ${p.date ? ` • ${new Date(p.date+'T00:00:00').toLocaleDateString('en-IN',{day:'2-digit',month:'short'})}` : ''}
          </div>
          ${p.notes ? `<div style="font-size:0.72rem;color:var(--muted);margin-top:4px;font-style:italic;">${p.notes}</div>` : ''}
        </div>
        ${waLink ? `<a href="${waLink}" target="_blank" onclick="event.stopPropagation()" style="text-decoration:none;flex-shrink:0;">
          <button class="btn btn-sm" style="background:#25D366;color:white;" onclick="event.stopPropagation()">📲</button>
        </a>` : ''}
      </div>
    </div>`;
  }).join('');
}

function init() {
  load();
  loadFeesSettings();
  loadPromoSettings();
  renderClassFilter();
  renderStudents();
  updateAllClassSelects();
  initRangePresets();
  initCalendar();
  renderGlance();
  const ALL_TABS = ['glance','students','attendance','report','monthly','fees','prospects','settings'];
  ALL_TABS.forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('hidden', t !== 'glance');
  });
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', i === 0);
  });
}

init();
</script>
