<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
// ─── DATA ─────────────────────────────────────────────
let db = {
  classes: ['Class 6-A', 'Class 7-B', 'Class 8-C'],
  students: [],
  attendance: {} // { 'YYYY-MM-DD': { studentId: 'P'|'A'|'L' } }
};

let editingStudentId = null;
let activeTab = 'students';

const AVATAR_COLORS = ['#4f46e5','#7c3aed','#059669','#d97706','#dc2626','#0891b2','#7c3aed','#be185d'];

function getColor(name) {
  let hash = 0;
  for (let c of (name||'')) hash = c.charCodeAt(0) + ((hash << 5) - hash);
  return AVATAR_COLORS[Math.abs(hash) % AVATAR_COLORS.length];
}

function initials(name) {
  return (name||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
}

function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2,6); }

// ─── STORAGE ──────────────────────────────────────────
function save() { localStorage.setItem('classbook_db', JSON.stringify(db)); }
function load() {
  const raw = localStorage.getItem('classbook_db');
  if (raw) db = JSON.parse(raw);
}

// ─── TABS ─────────────────────────────────────────────
function showTab(tab) {
  activeTab = tab;
  const ALL_TABS = ['glance','students','attendance','report','monthly','fees','prospects','settings'];
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', ALL_TABS[i] === tab);
  });
  ALL_TABS.forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('hidden', t !== tab);
  });
  if (tab === 'glance')     renderGlance();
  if (tab === 'attendance') initAttendance();
  if (tab === 'report')     renderReport();
  if (tab === 'monthly')    initMonthly();
  if (tab === 'fees')       renderFees();
  if (tab === 'prospects')  renderProspects();
}

// ─── STUDENTS ─────────────────────────────────────────
function renderStudents() {
  const q = document.getElementById('studentSearch').value.toLowerCase();
  const activeClass = document.querySelector('.class-chip.active')?.dataset.cls || '';
  let list = db.students;
  if (q) list = list.filter(s => s.name.toLowerCase().includes(q) || (s.roll||'').toLowerCase().includes(q));
  if (activeClass) list = list.filter(s => s.cls === activeClass);

  // Sort by class then roll then name
  list.sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    const ra = parseInt(a.roll)||999, rb = parseInt(b.roll)||999;
    if (ra !== rb) return ra - rb;
    return a.name.localeCompare(b.name);
  });

  const el = document.getElementById('studentList');
  if (!list.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">🎒</div><p>No students found.<br>Tap <b>Add Student</b> to get started!</p></div>`;
    return;
  }

  el.innerHTML = list.map(s => {
    const pct = getAttPct(s.id);
    const pillClass = pct >= 75 ? 'pill-green' : pct >= 50 ? 'pill-yellow' : 'pill-red';
    return `<div class="card student-card" onclick="openProfile('${s.id}')">
      <div class="avatar" style="background:${getColor(s.name)}">${initials(s.name)}</div>
      <div class="student-info">
        <div class="student-name">${s.name}</div>
        <div class="student-meta">${s.cls}${s.roll ? ' • Roll #'+s.roll : ''}${s.parent ? ' • 👨‍👧 '+s.parent : ''}</div>
      </div>
      <span class="attendance-pill ${pillClass}">${pct}%</span>
    </div>`;
  }).join('');
}

function renderClassFilter() {
  const el = document.getElementById('class-filter');
  el.innerHTML = `<div class="class-chip active" data-cls="" onclick="selectClassFilter(this, '')">All</div>` +
    db.classes.map(c => `<div class="class-chip" data-cls="${c}" onclick="selectClassFilter(this,'${c}')">${c}</div>`).join('');
}

function selectClassFilter(el, cls) {
  document.querySelectorAll('.class-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderStudents();
}

function getAttPct(sid) {
  let total = 0, present = 0;
  for (const date in db.attendance) {
    const rec = db.attendance[date];
    if (rec[sid] !== undefined) { total++; if (rec[sid] === 'P') present++; }
  }
  return total === 0 ? 100 : Math.round((present/total)*100);
}

function openAddStudent() {
  editingStudentId = null;
  document.getElementById('studentModalTitle').textContent = 'Add Student';
  document.getElementById('deleteStudentBtn').style.display = 'none';
  ['sName','sRoll','sPhone','sPhone2','sAddress','sNotes'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('sDoj').value = '';
  document.getElementById('sFees').value = '';
  document.getElementById('sGender').value = '';
  populateClassSelect('sClass');
  openModal('studentModal');
}

function openEditStudent(id) {
  const s = db.students.find(x => x.id === id);
  if (!s) return;
  editingStudentId = id;
  document.getElementById('studentModalTitle').textContent = 'Edit Student';
  document.getElementById('deleteStudentBtn').style.display = '';
  document.getElementById('sName').value = s.name || '';
  document.getElementById('sRoll').value = s.roll || '';
  document.getElementById('sPhone').value = s.phone || '';
  document.getElementById('sPhone2').value = s.phone2 || '';
  document.getElementById('sAddress').value = s.address || '';
  document.getElementById('sNotes').value = s.notes || '';
  document.getElementById('sDoj').value = s.doj || '';
  document.getElementById('sFees').value = s.fees || '';
  document.getElementById('sGender').value = s.gender || '';
  populateClassSelect('sClass', s.cls);
  closeModal('profileModal');
  openModal('studentModal');
}

function saveStudent() {
  const name = document.getElementById('sName').value.trim();
  const cls = document.getElementById('sClass').value;
  if (!name) { alert('Name is required!'); return; }
  if (!cls) { alert('Class is required!'); return; }
  const data = {
    name, cls,
    roll: document.getElementById('sRoll').value.trim(),
    gender: document.getElementById('sGender').value,
    doj: document.getElementById('sDoj').value,
    fees: document.getElementById('sFees').value.trim(),
    phone: document.getElementById('sPhone').value.trim(),
    phone2: document.getElementById('sPhone2').value.trim(),
    address: document.getElementById('sAddress').value.trim(),
    notes: document.getElementById('sNotes').value.trim(),
  };
  if (editingStudentId) {
    const idx = db.students.findIndex(s => s.id === editingStudentId);
    db.students[idx] = { ...db.students[idx], ...data };
  } else {
    db.students.push({ id: uid(), ...data });
  }
  save(); renderStudents(); closeModal('studentModal');
}

function deleteStudent() {
  if (!confirm('Delete this student and all their attendance records?')) return;
  db.students = db.students.filter(s => s.id !== editingStudentId);
  for (const date in db.attendance) delete db.attendance[date][editingStudentId];
  save(); renderStudents(); closeModal('studentModal');
}

function openProfile(id) {
  const s = db.students.find(x => x.id === id);
  if (!s) return;
  const pct = getAttPct(id);
  const pillClass = pct >= 75 ? 'pill-green' : pct >= 50 ? 'pill-yellow' : 'pill-red';

  // Count records
  let total=0, present=0, absent=0, late=0;
  for (const date in db.attendance) {
    const v = db.attendance[date][id];
    if (v !== undefined) { total++; if(v==='P')present++; else if(v==='A')absent++; else if(v==='L')late++; }
  }

  document.getElementById('profileContent').innerHTML = `
    <div class="profile-header">
      <div class="profile-avatar" style="background:${getColor(s.name)}">${initials(s.name)}</div>
      <div class="profile-name">${s.name}</div>
      <div class="profile-sub">${s.cls}${s.roll ? ' • Roll #'+s.roll : ''}${s.gender ? ' • '+s.gender : ''}</div>
      <div style="margin-top:10px;">
        <span class="attendance-pill ${pillClass}" style="font-size:0.9rem;padding:6px 14px;">${pct}% Attendance</span>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0;">
      <div class="summary-card"><div class="summary-num" style="color:var(--green)">${present}</div><div class="summary-label">Present</div></div>
      <div class="summary-card"><div class="summary-num" style="color:var(--red)">${absent}</div><div class="summary-label">Absent</div></div>
      <div class="summary-card"><div class="summary-num" style="color:var(--yellow)">${late}</div><div class="summary-label">Late</div></div>
    </div>
    <div class="info-grid">
      ${s.phone ? `<div class="info-item"><div class="info-label">Contact 1</div><div class="info-value"><a href="tel:${s.phone}" style="color:var(--accent);text-decoration:none;">${s.phone}</a></div></div>` : ''}
      ${s.phone2 ? `<div class="info-item"><div class="info-label">Contact 2</div><div class="info-value"><a href="tel:${s.phone2}" style="color:var(--accent);text-decoration:none;">${s.phone2}</a></div></div>` : ''}
      ${s.doj ? `<div class="info-item"><div class="info-label">Date of Joining</div><div class="info-value">${s.doj}</div></div>` : ''}
      ${s.fees ? `<div class="info-item"><div class="info-label">Fees Amount</div><div class="info-value">₹${Number(s.fees).toLocaleString('en-IN')}</div></div>` : ''}
      ${s.address ? `<div class="info-item" style="grid-column:1/-1;"><div class="info-label">Address</div><div class="info-value">${s.address}</div></div>` : ''}
      ${s.notes ? `<div class="info-item" style="grid-column:1/-1;"><div class="info-label">Notes</div><div class="info-value">${s.notes}</div></div>` : ''}
    </div>
    <div class="flex-row mt-12">
      <button class="btn btn-primary" style="flex:1" onclick="openEditStudent('${id}')">✏️ Edit</button>
    </div>
  `;
  openModal('profileModal');
}

// ─── ATTENDANCE ───────────────────────────────────────
function initAttendance() {
  const dateEl = document.getElementById('attDate');
  if (!dateEl.value) dateEl.value = todayStr();
  populateClassSelect('attClassFilter', '', true);
  renderCalStrip();
  loadAttendanceForDate();
}

function todayStr() {
  return new Date().toISOString().slice(0,10);
}

function renderCalStrip() {
  const today = new Date();
  const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  let html = '';
  for (let i = -3; i <= 3; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() + i);
    const ds = d.toISOString().slice(0,10);
    const isActive = ds === document.getElementById('attDate').value;
    html += `<div class="cal-day ${isActive?'active':''}" onclick="selectCalDay('${ds}')">
      <div class="day-name">${days[d.getDay()]}</div>
      <div class="day-num">${d.getDate()}</div>
    </div>`;
  }
  document.getElementById('calStrip').innerHTML = html;
}

function selectCalDay(ds) {
  document.getElementById('attDate').value = ds;
  renderCalStrip();
  loadAttendanceForDate();
}

function loadAttendanceForDate() {
  const date = document.getElementById('attDate').value;
  const clsFilter = document.getElementById('attClassFilter').value;
  let students = db.students;
  if (clsFilter) students = students.filter(s => s.cls === clsFilter);
  students = [...students].sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    return (parseInt(a.roll)||999) - (parseInt(b.roll)||999);
  });

  const rec = db.attendance[date] || {};

  if (!students.length) {
    document.getElementById('attList').innerHTML = `<div class="empty-state"><div class="empty-icon">🎒</div><p>No students found. Add students first!</p></div>`;
    return;
  }

  document.getElementById('attList').innerHTML = students.map(s => {
    const status = rec[s.id] || '';
    return `<div class="att-row ${status==='P'?'present':status==='A'?'absent':status==='L'?'late':''}" id="ar-${s.id}">
      <div class="avatar" style="background:${getColor(s.name)};width:36px;height:36px;font-size:0.9rem;">${initials(s.name)}</div>
      <div class="att-name">${s.name}<br><span style="font-size:0.72rem;color:var(--muted)">${s.cls}${s.roll?' #'+s.roll:''}</span></div>
      <div class="att-btns">
        <button class="att-btn p ${status==='P'?'active':''}" onclick="markAtt('${s.id}','P')">P</button>
        <button class="att-btn a ${status==='A'?'active':''}" onclick="markAtt('${s.id}','A')">A</button>
        <button class="att-btn l ${status==='L'?'active':''}" onclick="markAtt('${s.id}','L')">L</button>
      </div>
    </div>`;
  }).join('');
}

function markAtt(sid, status) {
  const date = document.getElementById('attDate').value;
  if (!db.attendance[date]) db.attendance[date] = {};
  const current = db.attendance[date][sid];
  if (current === status) {
    delete db.attendance[date][sid];
    status = '';
  } else {
    db.attendance[date][sid] = status;
  }
  save();
  // Update row
  const row = document.getElementById('ar-'+sid);
  row.className = 'att-row ' + (status==='P'?'present':status==='A'?'absent':status==='L'?'late':'');
  row.querySelectorAll('.att-btn').forEach(btn => {
    btn.classList.toggle('active', btn.classList.contains(status.toLowerCase()) && status !== '');
  });
}

function saveAttendance() {
  save();
  const btn = event.target;
  btn.textContent = '✅ Saved!';
  setTimeout(() => btn.textContent = '💾 Save', 1500);
}

// ─── REPORT ───────────────────────────────────────────
function renderReport() {
  const clsFilter = document.getElementById('reportClassFilter').value;
  let students = db.students;
  if (clsFilter) students = students.filter(s => s.cls === clsFilter);
  students = [...students].sort((a,b) => {
    if (a.cls !== b.cls) return a.cls.localeCompare(b.cls);
    return (parseInt(a.roll)||999) - (parseInt(b.roll)||999);
  });

  const allDates = Object.keys(db.attendance).sort();
  let totalPresent=0, totalAbsent=0, totalLate=0;

  const rows = students.map(s => {
    let p=0, a=0, l=0, t=0;
    for (const date of allDates) {
      const v = db.attendance[date]?.[s.id];
      if (v !== undefined) { t++; if(v==='P')p++; else if(v==='A')a++; else if(v==='L')l++; }
    }
    totalPresent+=p; totalAbsent+=a; totalLate+=l;
    const pct = t===0 ? '—' : Math.round((p/t)*100)+'%';
    const pctNum = t===0 ? 100 : Math.round((p/t)*100);
    const clr = pctNum>=75 ? '#065f46' : pctNum>=50 ? '#92400e' : '#991b1b';
    const bg = pctNum>=75 ? '#d1fae5' : pctNum>=50 ? '#fef3c7' : '#fee2e2';
    return `<tr>
      <td>${s.cls}</td>
      <td>${s.roll||'—'}</td>
      <td><b>${s.name}</b></td>
      <td style="color:var(--green);font-weight:700;">${p}</td>
      <td style="color:var(--red);font-weight:700;">${a}</td>
      <td style="color:var(--yellow);font-weight:700;">${l}</td>
      <td><span style="background:${bg};color:${clr};padding:3px 10px;border-radius:50px;font-weight:700;font-size:0.8rem;">${pct}</span></td>
    </tr>`;
  }).join('');

  document.getElementById('summaryGrid').innerHTML = `
    <div class="summary-card"><div class="summary-num" style="color:var(--accent)">${students.length}</div><div class="summary-label">Students</div></div>
    <div class="summary-card"><div class="summary-num" style="color:var(--accent)">${allDates.length}</div><div class="summary-label">Days Recorded</div></div>
    <div class="summary-card"><div class="summary-num" style="color:var(--green)">${totalPresent}</div><div class="summary-label">Total Present</div></div>
  `;

  document.getElementById('reportTable').innerHTML = students.length ? `
    <thead><tr>
      <th>Class</th><th>Roll</th><th>Name</th>
      <th>✅ P</th><th>❌ A</th><th>⏰ L</th><th>%</th>
    </tr></thead>
    <tbody>${rows}</tbody>
  ` : `<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--muted);">No data yet</td></tr>`;
}

// ─── CLASS MANAGEMENT ─────────────────────────────────
function openClassModal() {
  renderClassList();
  openModal('classModal');
}

function renderClassList() {
  document.getElementById('classList').innerHTML = db.classes.map((c,i) => `
    <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);">
      <span style="flex:1;font-weight:600">${c}</span>
      <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;" onclick="removeClass(${i})">Remove</button>
    </div>
  `).join('') || '<p style="color:var(--muted);font-size:0.85rem;">No classes yet.</p>';
}

function addClass() {
  const val = document.getElementById('newClassName').value.trim();
  if (!val) return;
  if (!db.classes.includes(val)) { db.classes.push(val); save(); }
  document.getElementById('newClassName').value = '';
  renderClassList();
  updateAllClassSelects();
  renderClassFilter();
}

function removeClass(idx) {
  const cls = db.classes[idx];
  if (db.students.some(s => s.cls === cls)) {
    alert(`Cannot remove "${cls}" — students are assigned to it. Reassign them first.`);
    return;
  }
  db.classes.splice(idx,1);
  save();
  renderClassList();
  updateAllClassSelects();
  renderClassFilter();
}

function populateClassSelect(id, selected='', addAll=false) {
