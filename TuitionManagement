<div class="modal-overlay" id="classModal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Manage Classes</div>
      <button class="close-btn" onclick="closeModal('classModal')">✕</button>
    </div>
    <div id="classList" style="margin-bottom:16px;"></div>
    <div style="display:flex;gap:10px;">
      <input type="text" id="newClassName" placeholder="e.g. Class 8-B" style="flex:1;">
