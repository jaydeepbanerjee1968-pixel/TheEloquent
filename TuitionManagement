function getDaysSince(dateStr) {
  if (!dateStr) return null;
  const d = new Date(dateStr + 'T00:00:00');
  const today = new Date(); today.setHours(0,0,0,0);
  return Math.floor((today - d) / (1000*60*60*24));
}

function getFeesStatus(student) {
  if (!student.doj) return null;
  const daysSince = getDaysSince(student.doj);
  if (daysSince === null || daysSince < 0) return null;
  // Cycle: due every 31 days starting from day 31
  const cycle = Math.floor(daysSince / 31);
  const daysIntoCycle = daysSince % 31;
  const daysUntilDue = 31 - daysIntoCycle;
  const isDue = daysIntoCycle === 0 && daysSince > 0; // exactly on cycle boundary
  const isOverdue = daysIntoCycle > 0 && daysIntoCycle <= 7; // within 7-day grace after due
  const nextDueDate = new Date(student.doj + 'T00:00:00');
  nextDueDate.setDate(nextDueDate.getDate() + (cycle + 1) * 31);
  return { daysSince, cycle, daysIntoCycle, daysUntilDue, isDue, isOverdue, nextDueDate, cycleNum: cycle + 1 };
}

function buildWhatsAppLink(phone, msg) {
