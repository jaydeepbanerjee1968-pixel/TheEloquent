<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="The Eloquent">
<meta name="theme-color" content="#4f46e5">
<title>The Eloquent — Student Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f0f4ff;
    --card: #ffffff;
    --accent: #4f46e5;
    --accent2: #7c3aed;
    --green: #10b981;
    --red: #ef4444;
    --yellow: #f59e0b;
    --text: #1e1b4b;
    --muted: #6b7280;
    --border: #e0e7ff;
    --shadow: 0 4px 24px rgba(79,70,229,0.10);
    --radius: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Quicksand', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: white;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 20px rgba(79,70,229,0.3);
    position: sticky; top: 0; z-index: 100;
  }
  .logo { font-family: 'Nunito', sans-serif; font-size: 1.5rem; font-weight: 900; letter-spacing: -0.5px; }
  .logo span { opacity: 0.7; font-weight: 600; font-size: 0.85rem; display: block; }
  header .class-badge {
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 50px;
    padding: 6px 14px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }
  header .class-badge:hover { background: rgba(255,255,255,0.3); }

  /* TABS */
  .tabs {
    display: flex;
    background: white;
    border-bottom: 2px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab {
    flex: 1;
    min-width: 90px;
    padding: 14px 10px;
    text-align: center;
    font-weight: 700;
    font-size: 0.82rem;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab .tab-icon { font-size: 1.2rem; display: block; margin-bottom: 2px; }

  /* CONTENT */
  .content { padding: 16px; max-width: 900px; margin: 0 auto; }

  /* SECTION HEADERS */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .section-title { font-family: 'Nunito', sans-serif; font-size: 1.2rem; font-weight: 800; }

  /* BUTTONS */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px;
    border-radius: 50px;
    border: none;
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary { background: var(--accent); color: white; box-shadow: 0 4px 12px rgba(79,70,229,0.3); }
  .btn-primary:hover { background: #4338ca; transform: translateY(-1px); }
  .btn-green { background: var(--green); color: white; }
  .btn-red { background: var(--red); color: white; }
  .btn-ghost { background: transparent; color: var(--accent); border: 2px solid var(--border); }
  .btn-sm { padding: 5px 12px; font-size: 0.78rem; }

  /* CARDS */
  .card {
    background: var(--card);
    border-radius: var(--radius);
    padding: 16px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    margin-bottom: 12px;
  }

  /* STUDENT CARD */
  .student-card {
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .student-card:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(79,70,229,0.15); }
  .avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    font-family: 'Nunito', sans-serif;
    font-size: 1.2rem; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: white;
  }
  .student-info { flex: 1; min-width: 0; }
  .student-name { font-weight: 700; font-size: 1rem; }
  .student-meta { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
  .attendance-pill {
    padding: 4px 10px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .pill-green { background: #d1fae5; color: #065f46; }
  .pill-yellow { background: #fef3c7; color: #92400e; }
  .pill-red { background: #fee2e2; color: #991b1b; }

  /* FORM */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media(max-width:500px) { .form-grid { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: 5px; }
  .form-group.full { grid-column: 1 / -1; }
  label { font-size: 0.8rem; font-weight: 700; color: var(--muted); }
  input, select, textarea {
    padding: 10px 14px;
    border: 2px solid var(--border);
    border-radius: 10px;
    font-family: 'Quicksand', sans-serif;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: white;
  }
  textarea { resize: vertical; min-height: 70px; }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(30,27,75,0.5);
    z-index: 200;
    padding: 16px;
    overflow-y: auto;
    align-items: flex-start;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: white;
    border-radius: 20px;
    padding: 24px;
    width: 100%;
    max-width: 520px;
    margin: auto;
    box-shadow: 0 20px 60px rgba(79,70,229,0.25);
    animation: slideUp 0.25s ease;
  }
  @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .modal-title { font-family: 'Nunito', sans-serif; font-size: 1.2rem; font-weight: 900; }
  .close-btn {
    background: var(--bg); border: none; width: 34px; height: 34px;
    border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center; color: var(--muted);
  }

  /* ATTENDANCE */
  .date-selector {
    display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .date-selector input[type=date] { flex: 1; min-width: 160px; }
  .att-list { display: flex; flex-direction: column; gap: 10px; }
  .att-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px;
    border-radius: 12px;
    background: var(--bg);
    border: 2px solid transparent;
    transition: all 0.15s;
  }
  .att-row.present { border-color: var(--green); background: #f0fdf4; }
  .att-row.absent { border-color: var(--red); background: #fef2f2; }
  .att-row.late { border-color: var(--yellow); background: #fffbeb; }
  .att-name { flex: 1; font-weight: 600; font-size: 0.9rem; }
  .att-btns { display: flex; gap: 6px; }
  .att-btn {
    padding: 5px 11px; border-radius: 50px; border: none;
    font-family: 'Quicksand', sans-serif; font-weight: 700; font-size: 0.75rem;
    cursor: pointer; opacity: 0.4; transition: opacity 0.15s, transform 0.1s;
  }
  .att-btn.active { opacity: 1; transform: scale(1.08); }
  .att-btn.p { background: var(--green); color: white; }
  .att-btn.a { background: var(--red); color: white; }
  .att-btn.l { background: var(--yellow); color: white; }

  /* SUMMARY CARDS */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }
  .summary-card {
    background: white;
    border-radius: 14px;
    padding: 14px 12px;
    text-align: center;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .summary-num { font-family: 'Nunito', sans-serif; font-size: 1.8rem; font-weight: 900; }
  .summary-label { font-size: 0.72rem; font-weight: 700; color: var(--muted); margin-top: 2px; }

  /* REPORT TABLE */
  .report-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .report-table th {
    background: var(--accent); color: white; padding: 10px 12px;
    text-align: left; font-weight: 700;
  }
  .report-table th:first-child { border-radius: 10px 0 0 0; }
  .report-table th:last-child { border-radius: 0 10px 0 0; }
  .report-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); }
  .report-table tr:hover td { background: #f5f3ff; }
  .report-table tr:last-child td { border-bottom: none; }

  /* PROFILE VIEW */
  .profile-header {
    text-align: center;
    padding: 20px 0 10px;
  }
  .profile-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    font-size: 2rem; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    color: white;
    margin: 0 auto 12px;
    font-family: 'Nunito', sans-serif;
  }
  .profile-name { font-family: 'Nunito', sans-serif; font-size: 1.4rem; font-weight: 900; }
  .profile-sub { color: var(--muted); font-size: 0.85rem; margin-top: 4px; }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 16px; }
  .info-item { background: var(--bg); border-radius: 10px; padding: 10px 14px; }
  .info-label { font-size: 0.72rem; font-weight: 700; color: var(--muted); }
  .info-value { font-weight: 600; font-size: 0.9rem; margin-top: 2px; }

  /* SEARCH */
  .search-bar {
    display: flex; align-items: center; gap: 10px;
    background: white;
    border-radius: 50px;
    padding: 0 16px;
    border: 2px solid var(--border);
    margin-bottom: 14px;
  }
  .search-bar input {
    border: none; background: transparent; padding: 11px 0;
    flex: 1;
  }
  .search-bar input:focus { outline: none; }
  .search-icon { color: var(--muted); font-size: 1rem; }

  /* EMPTY STATE */
  .empty-state { text-align: center; padding: 40px 20px; color: var(--muted); }
  .empty-state .empty-icon { font-size: 3rem; margin-bottom: 10px; }
  .empty-state p { font-size: 0.9rem; }

  /* CLASS SELECTOR */
  .class-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  .class-chip {
    padding: 6px 14px; border-radius: 50px;
    background: white; border: 2px solid var(--border);
    font-size: 0.8rem; font-weight: 700; cursor: pointer;
    transition: all 0.15s; color: var(--muted);
  }
  .class-chip.active { background: var(--accent); color: white; border-color: var(--accent); }

  /* SETTINGS */
  .settings-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0; border-bottom: 1px solid var(--border);
  }
  .settings-item:last-child { border-bottom: none; }
  .settings-label { font-weight: 700; font-size: 0.9rem; }
  .settings-sub { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

  /* MINI CALENDAR STRIP */
  .cal-strip { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 6px; scrollbar-width: none; margin-bottom: 14px; }
  .cal-strip::-webkit-scrollbar { display: none; }
  .cal-day {
    min-width: 46px; padding: 8px 0; border-radius: 12px;
    text-align: center; cursor: pointer;
    border: 2px solid var(--border);
    background: white;
    transition: all 0.15s;
  }
  .cal-day.active { background: var(--accent); border-color: var(--accent); color: white; }
  .cal-day .day-name { font-size: 0.65rem; font-weight: 700; opacity: 0.7; }
  .cal-day .day-num { font-family: 'Nunito', sans-serif; font-size: 1.1rem; font-weight: 900; margin-top: 2px; }

  /* MONTHLY GRID */
  .monthly-table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
  .monthly-table th {
    background: var(--accent); color: white; padding: 8px 6px;
    text-align: center; font-weight: 700; white-space: nowrap;
    position: sticky; top: 0; z-index: 2;
  }
  .monthly-table th.name-col { text-align: left; min-width: 130px; position: sticky; left: 0; z-index: 3; background: var(--accent); }
  .monthly-table td { padding: 7px 6px; border-bottom: 1px solid var(--border); text-align: center; white-space: nowrap; }
  .monthly-table td.name-col {
    text-align: left; font-weight: 700; font-size: 0.8rem;
    position: sticky; left: 0; background: white; z-index: 1;
    border-right: 2px solid var(--border);
    min-width: 130px;
  }
  .monthly-table tr:nth-child(even) td { background: #f8f8ff; }
  .monthly-table tr:nth-child(even) td.name-col { background: #f8f8ff; }
  .monthly-table tr:hover td { background: #ede9fe; }
  .monthly-table tr:hover td.name-col { background: #ede9fe; }
  .day-cell { width: 28px; }
  .dc-p { background: #d1fae5; color: #065f46; border-radius: 4px; font-weight: 700; padding: 2px 4px; }
  .dc-a { background: #fee2e2; color: #991b1b; border-radius: 4px; font-weight: 700; padding: 2px 4px; }
  .dc-l { background: #fef3c7; color: #92400e; border-radius: 4px; font-weight: 700; padding: 2px 4px; }
  .dc-h { background: #e5e7eb; color: #6b7280; border-radius: 4px; padding: 2px 4px; }
  .monthly-table td.summary-col { font-weight: 700; font-size: 0.8rem; border-left: 2px solid var(--border); }
  .monthly-table th.summary-col { border-left: 2px solid rgba(255,255,255,0.3); }


  .flex-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .mt-12 { margin-top: 12px; }
  .text-center { text-align: center; }
  .hidden { display: none !important; }

  /* ─── AT A GLANCE ─────────────────────────────────── */
  .glance-card {
    background: white;
    border-radius: 14px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .glance-top {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px 10px;
  }
  .glance-name { font-weight: 800; font-size: 0.95rem; font-family:'Nunito',sans-serif; }
  .glance-meta { font-size: 0.72rem; color: var(--muted); margin-top: 1px; }
  .glance-panels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
  }
  .glance-panel {
    padding: 10px 8px;
    text-align: center;
    border-right: 1px solid var(--border);
  }
  .glance-panel:last-child { border-right: none; }
  .glance-panel-label {
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .glance-big {
    font-family: 'Nunito', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
  }
  .glance-sub {
    font-size: 0.68rem;
    color: var(--muted);
    margin-top: 3px;
  }
  .glance-bar-wrap {
    height: 5px;
    background: var(--border);
    border-radius: 10px;
    margin: 5px 6px 0;
    overflow: hidden;
  }
  .glance-bar { height: 100%; border-radius: 10px; transition: width 0.4s; }
  .glance-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 4px;
    vertical-align: middle;
  }
  .top-strip-card {
    background: white;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    padding: 11px 8px;
    text-align: center;
  }
  .top-strip-num {
    font-family: 'Nunito', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
  }
  .top-strip-label { font-size: 0.62rem; font-weight: 700; color: var(--muted); margin-top: 2px; }

  /* ─── STUDENT PICKER ──────────────────────────────── */
  .picker-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 10px;
    border: 2px solid var(--border);
    background: var(--bg);
    cursor: pointer;
    transition: all 0.12s;
    user-select: none;
  }
  .picker-row:hover { border-color: var(--accent); background: #eef2ff; }
  .picker-row.selected { border-color: var(--accent); background: #eef2ff; }
  .picker-row input[type=checkbox] {
    width: 18px; height: 18px; flex-shrink: 0;
    accent-color: var(--accent);
    cursor: pointer;
    border-radius: 4px;
    padding: 0; border: none; background: transparent;
  }
  .picker-name { font-weight: 700; font-size: 0.88rem; flex: 1; min-width: 0; }
  .picker-meta { font-size: 0.7rem; color: var(--muted); white-space: nowrap; }

  /* ─── TOGGLE SWITCH ───────────────────────────────── */
  .toggle-switch { position:relative; display:inline-block; width:52px; height:28px; flex-shrink:0; }
  .toggle-switch input { opacity:0; width:0; height:0; }
  .toggle-slider {
    position:absolute; cursor:pointer; inset:0;
    background:#e5e7eb; border-radius:28px; transition:0.3s;
  }
  .toggle-slider::before {
    content:''; position:absolute;
    width:22px; height:22px; left:3px; bottom:3px;
    background:white; border-radius:50%; transition:0.3s;
    box-shadow: 0 2px 6px rgba(0,0,0,0.18);
  }
  .toggle-switch input:checked + .toggle-slider { background:var(--green); }
  .toggle-switch input:checked + .toggle-slider::before { transform:translateX(24px); }

  /* ─── CALENDAR RANGE PICKER ───────────────────────── */
  .range-preset {
    padding: 5px 12px;
    border-radius: 50px;
    border: 2px solid var(--border);
    background: white;
    font-family: 'Quicksand', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    color: var(--muted);
    transition: all 0.15s;
  }
  .range-preset.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .cal-hdr {
    text-align: center;
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--muted);
    text-transform: uppercase;
    padding: 3px 0;
  }
  .mini-cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.12s;
    user-select: none;
    position: relative;
  }
  .mini-cal-day.empty { cursor: default; }
  .mini-cal-day.has-data::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }
  .mini-cal-day.today { font-weight: 900; border: 2px solid var(--accent); color: var(--accent); }
  .mini-cal-day.in-range { background: #e0e7ff; color: var(--accent); border-radius: 0; }
  .mini-cal-day.range-start { background: var(--accent); color: white; border-radius: 8px 0 0 8px; }
  .mini-cal-day.range-end   { background: var(--accent); color: white; border-radius: 0 8px 8px 0; }
  .mini-cal-day.range-start.range-end { border-radius: 8px; }
  .mini-cal-day:not(.empty):not(.other-month):hover { background: #c7d2fe; }
  .mini-cal-day.other-month { color: #d1d5db; cursor: default; }

  /* ─── TOGGLE SWITCH ───────────────────────────────── */
  .toggle-switch { position:relative; display:inline-block; width:52px; height:28px; flex-shrink:0; }
  .toggle-switch input { opacity:0; width:0; height:0; }
  .toggle-slider {
    position:absolute; cursor:pointer; inset:0;
    background:#d1d5db; border-radius:28px; transition:0.3s;
  }
  .toggle-slider::before {
    content:''; position:absolute;
    width:22px; height:22px; left:3px; bottom:3px;
    background:white; border-radius:50%; transition:0.3s;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }
  .toggle-switch input:checked + .toggle-slider { background: var(--green); }
  .toggle-switch input:checked + .toggle-slider::before { transform: translateX(24px); }

  /* ─── FEES & PROSPECT CARDS ────────────────────────── */
  .fees-card {
    background:white; border-radius:14px;
    border:1px solid var(--border); box-shadow:var(--shadow);
    margin-bottom:10px; overflow:hidden;
  }
  .fees-card-top {
    display:flex; align-items:center; gap:12px; padding:12px 14px;
  }
  .fees-card-actions {
    display:flex; gap:8px; padding:10px 14px;
    border-top:1px solid var(--border); background:#fafafa;
    flex-wrap:wrap;
  }
  .wa-btn {
    display:inline-flex; align-items:center; gap:6px;
    padding:7px 14px; border-radius:50px; border:none;
    background:#25d366; color:white;
    font-family:'Quicksand',sans-serif; font-weight:700;
    font-size:0.8rem; cursor:pointer; text-decoration:none;
    transition:all 0.15s;
  }
  .wa-btn:hover { background:#1ebe5d; transform:translateY(-1px); }
  .prospect-card {
    background:white; border-radius:14px;
    border:1px solid var(--border); box-shadow:var(--shadow);
    margin-bottom:10px; padding:14px;
    cursor:pointer; transition:transform 0.15s, box-shadow 0.15s;
  }
  .prospect-card:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(79,70,229,0.15); }
  .prospect-top { display:flex; align-items:flex-start; gap:12px; }
  .prospect-status-badge {
    padding:3px 10px; border-radius:50px; font-size:0.72rem;
    font-weight:700; white-space:nowrap; display:inline-block; margin-top:4px;
  }
  .status-New            { background:#dbeafe; color:#1e40af; }
  .status-Contacted      { background:#ede9fe; color:#5b21b6; }
  .status-Interested     { background:#fef3c7; color:#92400e; }
  .status-Converted      { background:#d1fae5; color:#065f46; }
  .status-Not-Interested { background:#fee2e2; color:#991b1b; }

  /* ─── MOBILE OPTIMISATION ─────────────────────────── */
  @media (max-width: 600px) {
    header {
      padding: 12px 14px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .logo { font-size: 1.15rem; line-height: 1.25; }
    .logo span { font-size: 0.7rem; }
    header .class-badge { font-size: 0.72rem; padding: 5px 11px; }

    .tab { min-width: 76px; padding: 11px 6px; font-size: 0.72rem; }
    .tab .tab-icon { font-size: 1.05rem; }

    .content { padding: 10px; }
    .section-title { font-size: 1.05rem; }
    .btn { padding: 9px 14px; font-size: 0.8rem; }
    .btn-sm { padding: 6px 11px; font-size: 0.72rem; }

    .card { padding: 12px; border-radius: 12px; }
    .form-grid { gap: 10px; }

    .summary-grid { gap: 7px; }
    .summary-num { font-size: 1.4rem; }
    .summary-label { font-size: 0.62rem; }
    .summary-card { padding: 10px 6px; border-radius: 10px; }

    .modal { padding: 18px; border-radius: 16px; max-width: 100%; }
    .modal-title { font-size: 1.05rem; }

    .student-card { gap: 10px; padding: 12px; }
    .avatar { width: 40px; height: 40px; font-size: 1rem; }
    .student-name { font-size: 0.92rem; }
    .student-meta { font-size: 0.72rem; }
    .attendance-pill { font-size: 0.68rem; padding: 3px 8px; }

    .date-selector { gap: 8px; }
    .att-row { padding: 10px 11px; gap: 9px; }
    .att-name { font-size: 0.82rem; }
    .att-btn { padding: 6px 13px; font-size: 0.8rem; }

    .cal-day { min-width: 40px; padding: 6px 0; }

    .monthly-table { font-size: 0.68rem; }
    .monthly-table th, .monthly-table td { padding: 6px 4px; }
    .monthly-table th.name-col, .monthly-table td.name-col { min-width: 105px; }
    .day-cell { width: 24px; }

    .class-chips { gap: 6px; }
    .class-chip { padding: 5px 11px; font-size: 0.72rem; }

    .search-bar input { padding: 9px 0; font-size: 0.85rem; }

    .glance-big { font-size: 1.2rem; }
    .glance-panel { padding: 8px 5px; }
    .glance-panel-label { font-size: 0.55rem; }
    .glance-sub { font-size: 0.6rem; }
    .glance-name { font-size: 0.88rem; }
    .top-strip-num { font-size: 1.3rem; }
    .top-strip-label { font-size: 0.58rem; }

    .report-table { font-size: 0.74rem; }
    .report-table th, .report-table td { padding: 8px 8px; }
  }

  @media (max-width: 380px) {
    .logo { font-size: 1rem; }
    .summary-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }

  @media (hover: none) {
    .btn, .tab, .class-chip, .att-btn, .student-card { -webkit-tap-highlight-color: rgba(79,70,229,0.15); }
  }
</style>
</head>
<body>

<header>
  <div class="logo">
    The Eloquent
    <span>Santragachi, Howrah, India-711110</span>
  </div>
  <div class="class-badge" onclick="openClassModal()">🏫 <span id="currentClassLabel">All Classes</span></div>
</header>

<div class="tabs">
  <div class="tab active" onclick="showTab('glance')"><span class="tab-icon">🔭</span>At a Glance</div>
  <div class="tab" onclick="showTab('students')"><span class="tab-icon">👨‍🎓</span>Students</div>
  <div class="tab" onclick="showTab('attendance')"><span class="tab-icon">✅</span>Attendance</div>
  <div class="tab" onclick="showTab('report')"><span class="tab-icon">📊</span>Report</div>
  <div class="tab" onclick="showTab('monthly')"><span class="tab-icon">📅</span>Monthly</div>
  <div class="tab" onclick="showTab('fees')"><span class="tab-icon">💰</span>Fees</div>
  <div class="tab" onclick="showTab('prospects')"><span class="tab-icon">🌱</span>Prospects</div>
  <div class="tab" onclick="showTab('settings')"><span class="tab-icon">⚙️</span>Settings</div>
</div>

<div class="content">

  <!-- AT A GLANCE TAB -->
  <div id="tab-glance">
    <div class="section-header">
      <div class="section-title">🔭 At a Glance</div>
      <select id="glanceClassFilter" onchange="renderGlance()" style="max-width:150px;font-size:0.82rem;">
        <option value="">All Classes</option>
      </select>
    </div>

    <!-- Top 3 summary strip -->
    <div id="glanceTopStrip" style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;"></div>

    <!-- Calendar range picker -->
    <div class="card" style="padding:14px;margin-bottom:12px;">
      <div style="font-size:0.75rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">📆 Custom Date Range</div>

      <!-- Quick preset chips -->
      <div style="display:flex;gap:7px;flex-wrap:wrap;margin-bottom:12px;" id="rangePresets">
        <button class="range-preset" data-range="thisweek">This Week</button>
        <button class="range-preset" data-range="lastweek">Last Week</button>
        <button class="range-preset" data-range="thismonth">This Month</button>
        <button class="range-preset" data-range="lastmonth">Last Month</button>
        <button class="range-preset" data-range="last7">Last 7 Days</button>
        <button class="range-preset" data-range="last30">Last 30 Days</button>
        <button class="range-preset active" data-range="custom">Custom</button>
      </div>

      <!-- Mini calendar -->
      <div id="miniCalContainer">
        <!-- nav row -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <button onclick="calNav(-1)" style="background:var(--bg);border:none;border-radius:8px;padding:5px 10px;font-size:1rem;cursor:pointer;font-weight:700;">‹</button>
          <div id="calMonthLabel" style="font-family:'Nunito',sans-serif;font-weight:800;font-size:0.95rem;"></div>
          <button onclick="calNav(1)"  style="background:var(--bg);border:none;border-radius:8px;padding:5px 10px;font-size:1rem;cursor:pointer;font-weight:700;">›</button>
        </div>
        <!-- day-name headers -->
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px;">
          <div class="cal-hdr">Mo</div><div class="cal-hdr">Tu</div><div class="cal-hdr">We</div>
          <div class="cal-hdr">Th</div><div class="cal-hdr">Fr</div><div class="cal-hdr">Sa</div><div class="cal-hdr">Su</div>
        </div>
        <!-- day cells -->
        <div id="miniCalGrid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;"></div>
      </div>

      <!-- Selected range display -->
      <div id="rangeDisplay" style="margin-top:10px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
        <div style="font-size:0.8rem;font-weight:700;color:var(--text);" id="rangeSummaryText"></div>
        <button class="btn btn-primary btn-sm" onclick="applyRange()">Apply →</button>
      </div>
    </div>

    <!-- Custom range label -->
    <div id="glanceWeekLabel" style="font-size:0.78rem;font-weight:700;color:var(--muted);margin-bottom:8px;letter-spacing:0.04em;text-transform:uppercase;"></div>

    <!-- Student name picker -->
    <div class="card" style="padding:14px;margin-bottom:12px;" id="studentPickerPanel">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:8px;flex-wrap:wrap;">
        <div style="font-size:0.75rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">👤 Pick Students</div>
        <div style="display:flex;gap:6px;">
          <button class="btn btn-sm btn-ghost" onclick="glanceSelectAll()">All</button>
          <button class="btn btn-sm btn-ghost" onclick="glanceSelectNone()">None</button>
        </div>
      </div>
      <div class="search-bar" style="margin-bottom:10px;">
        <span class="search-icon">🔍</span>
        <input type="text" id="pickerSearch" placeholder="Search student..." oninput="renderPicker()">
      </div>
      <div id="pickerList" style="display:flex;flex-direction:column;gap:6px;max-height:240px;overflow-y:auto;"></div>
      <div style="margin-top:10px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
        <div id="pickerCount" style="font-size:0.78rem;font-weight:700;color:var(--muted);"></div>
        <button class="btn btn-primary btn-sm" onclick="applyStudentPicker()">Show Selected →</button>
      </div>
    </div>

    <!-- Student glance cards -->
    <div id="glanceList"></div>
  </div>

  <!-- STUDENTS TAB -->
  <div id="tab-students">
    <div class="section-header">
      <div class="section-title">My Students</div>
      <button class="btn btn-primary" onclick="openAddStudent()">➕ Add Student</button>
    </div>
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="studentSearch" placeholder="Search by name or roll no..." oninput="renderStudents()">
    </div>
    <div id="class-filter" class="class-chips"></div>
    <div id="studentList"></div>
  </div>

  <!-- ATTENDANCE TAB -->
  <div id="tab-attendance" class="hidden">
    <div class="section-header">
      <div class="section-title">Mark Attendance</div>
      <button class="btn btn-green btn-sm" onclick="saveAttendance()">💾 Save</button>
    </div>
    <div class="date-selector">
      <input type="date" id="attDate" onchange="loadAttendanceForDate()">
      <select id="attClassFilter" onchange="loadAttendanceForDate()" style="max-width:160px;">
        <option value="">All Classes</option>
      </select>
    </div>
    <div id="calStrip" class="cal-strip"></div>
    <div id="attList" class="att-list"></div>
  </div>

  <!-- REPORT TAB -->
  <div id="tab-report" class="hidden">
    <div class="section-header">
      <div class="section-title">Attendance Report</div>
      <select id="reportClassFilter" onchange="renderReport()" style="max-width:160px;">
        <option value="">All Classes</option>
      </select>
    </div>
    <div class="summary-grid" id="summaryGrid"></div>
    <div class="card" style="overflow-x:auto;">
      <table class="report-table" id="reportTable"></table>
    </div>
  </div>

  <!-- MONTHLY REPORT TAB -->
  <div id="tab-monthly" class="hidden">
    <div class="section-header">
      <div class="section-title">📅 Monthly Report</div>
      <button class="btn btn-green btn-sm" onclick="exportMonthlyExcel()">⬇️ Export to Excel</button>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;align-items:center;">
      <select id="monthlyMonth" onchange="renderMonthly()" style="flex:1;min-width:130px;">
      </select>
      <select id="monthlyYear" onchange="renderMonthly()" style="flex:1;min-width:100px;">
      </select>
      <select id="monthlyClass" onchange="renderMonthly()" style="flex:1;min-width:140px;">
        <option value="">All Classes</option>
      </select>
    </div>
    <!-- Monthly Summary Cards -->
    <div class="summary-grid" id="monthlySummary" style="grid-template-columns:repeat(4,1fr);"></div>
    <!-- Monthly Grid Table -->
    <div class="card" style="overflow-x:auto;padding:0;">
      <div id="monthlyGrid"></div>
    </div>
  </div>


  <!-- FEES REMINDER TAB -->
  <div id="tab-fees" class="hidden">
    <div class="section-title" style="margin-bottom:14px;">💰 Fees Reminder</div>

    <!-- Master toggle card -->
    <div class="card" style="margin-bottom:12px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
          <div class="settings-label">📲 Reminder System</div>
          <div class="settings-sub" id="feesSystemStatus">Inactive — tap to activate</div>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" id="feesSystemToggle" onchange="toggleFeesSystem()">
          <span class="toggle-slider"></span>
        </label>
      </div>
      <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:0.78rem;color:var(--muted);line-height:1.5;">
        When active, students whose fees are due (every 31 days from joining date) will appear below. Your phone number <b>8777685849</b> is saved as sender reference.
      </div>
    </div>

    <!-- Reminder message editor -->
    <div class="card" style="margin-bottom:12px;">
      <div class="settings-label" style="margin-bottom:8px;">✏️ Reminder Message</div>
      <textarea id="feesMessageText" rows="4" style="width:100%;resize:vertical;" placeholder="Type your reminder message here...">Your fees for the current month is due. Please ignore the message if you have already paid.</textarea>
      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" onclick="saveFeesMessage()">💾 Save Message</button>
        <button class="btn btn-ghost btn-sm" onclick="resetFeesMessage()">↺ Reset Default</button>
      </div>
      <div style="margin-top:8px;font-size:0.72rem;color:var(--muted);">
        Variables: <b>{name}</b> = student name &nbsp;·&nbsp; <b>{fees}</b> = fees amount &nbsp;·&nbsp; <b>{class}</b> = class
      </div>
    </div>

    <!-- Summary strip -->
    <div id="feesDueSummary" style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px;"></div>

    <!-- Name picker + Send All toolbar -->
    <div class="card" style="padding:13px;margin-bottom:12px;" id="feesPickerPanel">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
        <div style="font-size:0.75rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">👤 Select Students</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="btn btn-ghost btn-sm" onclick="feesPickAll()">All</button>
          <button class="btn btn-ghost btn-sm" onclick="feesPickNone()">None</button>
          <button id="feesSendAllBtn" class="btn btn-sm" style="background:#25D366;color:white;display:none;" onclick="feesStartQueue()">📲 Send Queue</button>
        </div>
      </div>
      <div class="search-bar" style="margin-bottom:8px;">
        <span class="search-icon">🔍</span>
        <input type="text" id="feesPickerSearch" placeholder="Search student..." oninput="renderFees()">
      </div>
      <div id="feesPickerCount" style="font-size:0.75rem;font-weight:700;color:var(--muted);margin-bottom:4px;"></div>
    </div>

    <!-- Due students list -->
    <div id="feesDueLabel" style="font-size:0.78rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.04em;margin-bottom:8px;"></div>
    <div id="feesDueList"></div>
  </div>

  <!-- PROSPECTS TAB -->
  <div id="tab-prospects" class="hidden">
    <div class="section-header">
      <div class="section-title">🌱 Prospects</div>
      <button class="btn btn-primary btn-sm" onclick="openAddProspect()">➕ Add Prospect</button>
    </div>

    <!-- Promo message card -->
    <div class="card" style="margin-bottom:12px;">
      <div class="settings-label" style="margin-bottom:8px;">📣 Promotional Message</div>
      <textarea id="promoMessageText" rows="4" style="width:100%;resize:vertical;" placeholder="Type your promotional message here...">Hello! I am Jaydeep from The Eloquent, Santragachi, Howrah. We offer expert coaching in English Grammar, Literature, and Computer Skills for Classes 3–10 (ICSE, CBSE & WB Board). To know more or book a free demo class, please contact us.</textarea>
      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" onclick="savePromoMessage()">💾 Save Message</button>
        <button class="btn btn-green btn-sm" onclick="sendPromoToAll()">📲 Send to All</button>
      </div>
      <div style="margin-top:8px;font-size:0.72rem;color:var(--muted);">
        Available variables: <b>{name}</b> = prospect name
      </div>
    </div>

    <!-- Search -->
    <div class="search-bar" style="margin-bottom:12px;">
      <span class="search-icon">🔍</span>
      <input type="text" id="prospectSearch" placeholder="Search prospects..." oninput="renderProspects()">
    </div>

    <!-- Status filter chips -->
    <div class="class-chips" id="prospectStatusFilter" style="margin-bottom:12px;">
      <div class="class-chip active" data-status="" onclick="selectProspectFilter(this,'')">All</div>
      <div class="class-chip" data-status="New" onclick="selectProspectFilter(this,'New')">🆕 New</div>
      <div class="class-chip" data-status="Contacted" onclick="selectProspectFilter(this,'Contacted')">📞 Contacted</div>
      <div class="class-chip" data-status="Interested" onclick="selectProspectFilter(this,'Interested')">⭐ Interested</div>
      <div class="class-chip" data-status="Converted" onclick="selectProspectFilter(this,'Converted')">✅ Converted</div>
      <div class="class-chip" data-status="Not Interested" onclick="selectProspectFilter(this,'Not Interested')">❌ Not Interested</div>
    </div>

    <div id="prospectList"></div>
  </div>

  <div id="tab-settings" class="hidden">
    <div class="section-title" style="margin-bottom:16px;">Settings</div>
    <div class="card">
      <div class="settings-item">
        <div>
          <div class="settings-label">Manage Classes</div>
          <div class="settings-sub">Add or remove class sections</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="openClassModal()">Manage</button>
      </div>
      <div class="settings-item">
        <div>
          <div class="settings-label">Export Data</div>
          <div class="settings-sub">Download all data as JSON</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="exportData()">Export</button>
      </div>
      <div class="settings-item">
        <div>
          <div class="settings-label">Import Data</div>
          <div class="settings-sub">Restore from backup JSON</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('importFile').click()">Import</button>
      </div>
      <div class="settings-item">
        <div>
          <div class="settings-label">Clear All Data</div>
          <div class="settings-sub" style="color:#ef4444;">Permanently delete everything</div>
        </div>
        <button class="btn btn-sm" style="background:#fee2e2;color:#991b1b;" onclick="clearAllData()">Clear</button>
      </div>
    </div>
    <input type="file" id="importFile" class="hidden" accept=".json" onchange="importData(event)">

    <div class="card mt-12">
      <div class="settings-item" style="border:none;padding:0;">
        <div>
          <div class="settings-label">📚 ClassBook v1.0</div>
          <div class="settings-sub">Made for teachers • Data saved on your device</div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- ADD/EDIT PROSPECT MODAL -->
<div class="modal-overlay" id="prospectModal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="prospectModalTitle">Add Prospect</div>
      <button class="close-btn" onclick="closeModal('prospectModal')">✕</button>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" id="pName" placeholder="e.g. Rahul Das">
      </div>
      <div class="form-group">
        <label>Contact Number *</label>
        <input type="tel" id="pPhone" placeholder="e.g. 9876543210">
      </div>
      <div class="form-group">
        <label>Second Contact</label>
        <input type="tel" id="pPhone2" placeholder="Optional">
      </div>
      <div class="form-group">
        <label>Student Name (child)</label>
        <input type="text" id="pStudent" placeholder="e.g. Ananya Das">
      </div>
      <div class="form-group">
        <label>Interested In (Class)</label>
        <input type="text" id="pClass" placeholder="e.g. Class 7">
      </div>
      <div class="form-group">
        <label>Status</label>
        <select id="pStatus">
          <option value="New">🆕 New</option>
          <option value="Contacted">📞 Contacted</option>
          <option value="Interested">⭐ Interested</option>
          <option value="Converted">✅ Converted</option>
          <option value="Not Interested">❌ Not Interested</option>
        </select>
      </div>
      <div class="form-group">
        <label>Date of Enquiry</label>
        <input type="date" id="pDate">
      </div>
      <div class="form-group">
        <label>Source</label>
        <select id="pSource">
          <option value="">— Select —</option>
          <option>WhatsApp</option>
          <option>Referral</option>
          <option>Walk-in</option>
          <option>Social Media</option>
          <option>Other</option>
        </select>
      </div>
      <div class="form-group full">
        <label>Notes</label>
        <textarea id="pNotes" placeholder="Any notes about this prospect..."></textarea>
      </div>
    </div>
    <div class="flex-row mt-12">
      <button class="btn btn-primary" onclick="saveProspect()" style="flex:1">💾 Save</button>
      <button id="deleteProspectBtn" class="btn btn-sm" style="background:#fee2e2;color:#991b1b;display:none;" onclick="deleteProspect()">🗑 Delete</button>
    </div>
  </div>
</div>

<!-- FEES QUEUE MODAL -->
<div class="modal-overlay" id="feesQueueModal">
  <div class="modal" style="max-width:420px;">
    <div class="modal-header">
      <div class="modal-title">📲 Sending Queue</div>
      <button class="close-btn" onclick="feesQueueCancel()">✕</button>
    </div>

    <!-- Progress bar -->
    <div style="background:var(--border);border-radius:10px;height:8px;margin-bottom:8px;overflow:hidden;">
      <div id="feesQueueBar" style="height:100%;background:var(--green);border-radius:10px;width:0%;transition:width 0.4s;"></div>
    </div>
    <div id="feesQueueStatus" style="font-size:0.78rem;font-weight:700;color:var(--muted);text-align:center;margin-bottom:14px;"></div>

    <!-- Step indicator -->
    <div id="feesQueueStepBox" style="background:#ede9fe;border-radius:12px;padding:10px 14px;margin-bottom:12px;display:flex;align-items:center;gap:10px;">
      <div style="font-size:1.4rem;">👆</div>
      <div style="font-size:0.8rem;font-weight:700;color:#4f46e5;line-height:1.4;" id="feesQueueInstruction">
        Tap <b>Open WhatsApp</b> below → Send the message → Come back here → Tap <b>Next →</b>
      </div>
    </div>

    <!-- Current student card -->
    <div id="feesQueueCard" style="background:var(--bg);border-radius:14px;padding:14px 16px;margin-bottom:12px;">
      <div style="display:flex;align-items:center;gap:12px;">
        <div id="feesQueueAvatar" style="width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Nunito',sans-serif;font-size:1.2rem;font-weight:900;color:white;flex-shrink:0;"></div>
        <div>
          <div id="feesQueueName" style="font-family:'Nunito',sans-serif;font-size:1.05rem;font-weight:900;"></div>
          <div id="feesQueueMeta" style="font-size:0.75rem;color:var(--muted);margin-top:2px;"></div>
          <div id="feesQueuePhone" style="font-size:0.8rem;font-weight:700;color:var(--accent);margin-top:3px;"></div>
        </div>
      </div>
    </div>

    <!-- Message preview -->
    <div style="background:#e7f8ee;border:1.5px solid #bbf7d0;border-radius:12px;padding:11px 13px;margin-bottom:14px;font-size:0.8rem;line-height:1.55;color:#065f46;" id="feesQueueMsg"></div>

    <!-- STEP 1: Open WhatsApp button (big, green) -->
    <a id="feesQueueWALink" href="#" target="_blank" style="text-decoration:none;display:block;margin-bottom:10px;">
      <button id="feesQueueOpenBtn" class="btn" style="width:100%;background:#25D366;color:white;font-size:1rem;padding:14px;border-radius:14px;font-weight:800;" onclick="feesQueueDidOpen()">
        📲 Step 1 — Open WhatsApp &amp; Send
      </button>
    </a>

    <!-- STEP 2: Next / Skip row — unlocked after Step 1 -->
    <div style="display:flex;gap:8px;">
      <button class="btn btn-ghost btn-sm" style="flex:1;" onclick="feesQueueSkip()">⏭ Skip</button>
      <button class="btn btn-primary" style="flex:2;padding:12px;font-size:0.95rem;border-radius:12px;opacity:0.4;" id="feesQueueNextBtn" onclick="feesQueueNext()" disabled>
        ✅ Step 2 — Sent? Next →
      </button>
    </div>
    <div style="margin-top:8px;font-size:0.7rem;color:var(--muted);text-align:center;" id="feesQueueHint">
      After tapping Open WhatsApp, send the message, then come back and tap <b>Sent? Next →</b>
    </div>
  </div>
</div>

